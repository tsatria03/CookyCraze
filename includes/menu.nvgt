ambslot=ambpool.play_stationary_extended("sounds/ambience/"+ambtype+".ogg", true,0,0,ambvolume,ambpitch,false);
mustrackslot=muspool.play_stationary_extended("sounds/ambience/"+mustype+".ogg", true,0,0,musvolume,muspitch,false);
ingame=true;
resetgame();
clickergame();
}
if (mres2==2)
{
ingame=false;
newgamemenu();
}
}
else
{
speak("Loading slot " + string(slotNumber));
m.fade_music();
if(introsfx==true) pool.play_stationary("sounds/misc/welcome" + random(1, 3) + ".ogg", false);
ambpool.destroy_sound(ambslot);
muspool.destroy_sound(mustrackslot);
ambslot=ambpool.play_stationary_extended("sounds/ambience/"+ambtype+".ogg", true,0,0,ambvolume,ambpitch,false);
mustrackslot=muspool.play_stationary_extended("sounds/ambience/"+mustype+".ogg", true,0,0,musvolume,muspitch,false);
ingame=true;
resetgame();
clickergame();
}
}
void mingamsmenu()
{
form.reset();
form.create_window("Mini games", false);
int jack=form.create_button("Play &blackjack");
int flip=form.create_button("Play &cookie flipper");
int lottery=form.create_button("Play cookie &lottery");
int dice=form.create_button("Play &dice roller");
int slots=form.create_button("play &slot machine");
form.focus(jack);
while(true)
{
wait(5);
form.monitor();
        if (key_pressed(KEY_ESCAPE))
        {
form.reset();
clickergame();
}
if(form.is_pressed(jack))
{
if(rank<10)
{
gameslot=pool.play_stationary("sounds/misc/gamefail.ogg", false);
dlg_buffer("Sorry "+playername+". This mini game is locked. Please be at rank 10 or higher to play this.", "critical");
form.reset();
mingamsmenu();
}
else
{
gameslot=pool.play_stationary("sounds/misc/gamelaunch.ogg", false);
jackgame();
}
}
if(form.is_pressed(flip))
{
if(rank<20)
{
gameslot=pool.play_stationary("sounds/misc/gamefail.ogg", false);
dlg_buffer("Sorry "+playername+". This mini game is locked. Please be at rank 20 or higher to play this.", "critical");
form.reset();
mingamsmenu();
}
else
{
gameslot=pool.play_stationary("sounds/misc/gamelaunch.ogg", false);
flipgame();
}
}
if(form.is_pressed(lottery))
{
if(rank<30)
{
gameslot=pool.play_stationary("sounds/misc/gamefail.ogg", false);
dlg_buffer("Sorry "+playername+". This mini game is locked. Please be at rank 30 or higher to play this.", "critical");
form.reset();
mingamsmenu();
}
else
{
gameslot=pool.play_stationary("sounds/misc/gamelaunch.ogg", false);
lotterygame();
}
}
if(form.is_pressed(dice))
{
if(rank<40)
{
gameslot=pool.play_stationary("sounds/misc/gamefail.ogg", false);
dlg_buffer("Sorry "+playername+". This mini game is locked. Please be at rank 40 or higher to play this.", "critical");
form.reset();
mingamsmenu();
}
else
{
gameslot=pool.play_stationary("sounds/misc/gamelaunch.ogg", false);
dicegame();
}
}
if(form.is_pressed(slots))
{
if(rank<50)
{
gameslot=pool.play_stationary("sounds/misc/gamefail.ogg", false);
dlg_buffer("Sorry "+playername+". This mini game is locked. Please be at rank 50 or higher to play this.", "critical");
form.reset();
mingamsmenu();
}
else
{
gameslot=pool.play_stationary("sounds/misc/gamelaunch.ogg", false);
slotsgame();
}
}
}
}
void infomenu()
{
    setupmenu(false);
    m.add_item("Achievement statistics", "achstats");
    m.add_item("Baker statistics", "statistics");
    m.add_item("Back", "back");
    m.intro_text = "Statistics menu. What would you like to view?";
    int mres = m.run(0, true);
    string sel = m.get_item_id(mres);
    if (mres == -1 || sel == "back")
    {
        form.reset();
        clickergame();
        return;
    }
    if (sel == "statistics")
        show_baker_statistics();
    else if (sel == "achstats")
        show_achievement_statistics(loadedAchievements, achievementsUnlocked, loadedAchievementCategories);
}
void lottery_scratch_menu()
{
    lottery_ticket_item[] ownedTickets;
    for (uint i = 0; i < loadedTickets.length(); i++)
    {
        if (loadedTickets[i].owned > 0)
            ownedTickets.insert_last(loadedTickets[i]);
    }
    if (ownedTickets.length() == 0)
    {
        dlg_buffer("You don't have any tickets to scratch. Buy some first!");
        return;
    }
    while (true)
    {
        ownedTickets.resize(0);
        for (uint i = 0; i < loadedTickets.length(); i++)
        {
            if (loadedTickets[i].owned > 0)
                ownedTickets.insert_last(loadedTickets[i]);
        }
        if (ownedTickets.length() == 0) return;
        setupmenu(false);
        for (uint i = 0; i < ownedTickets.length(); i++)
            m.add_item(ownedTickets[i].name + " — " + string(ownedTickets[i].owned) + " owned", ownedTickets[i].id);
        m.add_item("Back", "back");
        m.intro_text = "Select a ticket tier to scratch.";
        int res = m.run(0, true);
        if (res == -1) return;
        string sel = m.get_item_id(res);
        if (sel == "back") return;
        lottery_ticket_item@ ticket = null;
        int ticketIdx = -1;
        for (uint i = 0; i < loadedTickets.length(); i++)
        {
            if (loadedTickets[i].id == sel) { @ticket = loadedTickets[i]; ticketIdx = int(i); break; }
        }
        if (ticket is null || ticket.owned <= 0) continue;
        while (loadedTickets[ticketIdx].owned > 0)
        {
            setupmenu(false);
            m.add_item("Scratch one", "one");
            m.add_item("Scratch all (" + string(loadedTickets[ticketIdx].owned) + ")", "all");
            m.add_item("Back", "back2");
            m.intro_text = ticket.name + ". Choose how many to scratch.";
            int sres = m.run(0, true);
            if (sres == -1) break;
            string ssel = m.get_item_id(sres);
            if (ssel == "back2") break;
            if (ssel == "one")
                lottery_scratch_one(@ticket, ticketIdx);
            else if (ssel == "all")
                lottery_scratch_all(@ticket, ticketIdx);
        }
    }
}


void shopmenu()
{
setupmenu2();
m.add_item("buy upgrades", "bmu");
m.add_item("buy tickets", "bmt");
string cookieWord = (floor(cookies) == 1) ? "cookie" : "cookies";
m.add_item("sell cookies. You currently have " + format_number(cookies) + " " + cookieWord + ". Description: Each cookie sells for " + convert_to_currency(cookieSellPrice) + ".", "slm");
m.add_item("back", "back");
m.intro_text="Welcome to the cookie store. What would you like to do?";
int shop_start = 0;
if (shopmenu_last_id != "")
{
    int found = m.find_item_by_id(shopmenu_last_id);
    if (found != -1) shop_start = found;
}
int mres=m.run(shop_start, true);
string stm=m.get_item_id(mres);
if (mres != -1 && stm != "back")
    shopmenu_last_id = stm;
else
    shopmenu_last_id = "";
if(mres==-1)
{
pool.destroy_sound(alertslot);
pool.destroy_sound(storslot);
storambpool.destroy_sound(storambslot);
stormuspool.destroy_sound(stortrackslot);
speak("You're now exiting the cookie store.");
dlgplay("sounds/store/door_close.ogg");
ambpool.destroy_sound(ambslot);
muspool.destroy_sound(mustrackslot);
ambslot=ambpool.play_stationary_extended("sounds/ambience/"+ambtype+".ogg", true,0,0,ambvolume,ambpitch,false);
mustrackslot=muspool.play_stationary_extended("sounds/ambience/"+mustype+".ogg", true,0,0,musvolume,muspitch,false);
form.reset();
clickergame();
}
if(stm=="bmu")
{
buymenu();
}
if(stm=="bmt")
{
if (rank < 30)
{
pool.play_stationary("sounds/store/error.ogg", false);
dlgmessage_return("This shop is locked. Please reach rank 30 to access it.");
shopmenu();
}
else
{
lottery_buy_menu();
shopmenu();
}
}
if(stm=="slm")
{
vd.set_disallowed_chars("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ !@#$%^&*()[]{};:'\"\\|,.<>?/+-=`~_", false, "This character is not allowed.");
double sellableCookies = floor(cookies);
string sailam=vd.input_box("","How many cookies would you like to sell? Press enter to sell the maximum amount.", string(sellableCookies));
double cookiesToSell = floor(string_to_number(sailam));
    if (cookiesToSell <= 0)
    {
        pool.destroy_sound(alertslot);
        pool.play_stationary("sounds/store/fail.ogg", false);
        dlgmessage_return("Error! Please enter a valid number of cookies to sell!");
        shopmenu();
    }
    if (cookiesToSell > sellableCookies)
        cookiesToSell = sellableCookies;
double totalCoinsEarned = cookiesToSell * cookieSellPrice;
if (prestige_coin_multiplier > 0) totalCoinsEarned *= 1.0 + (prestige_coin_multiplier / 100.0);
cookies -= cookiesToSell;
coins += totalCoinsEarned;
stat_coins_earned += totalCoinsEarned;
play_coin_sound(totalCoinsEarned);
dlgmessage_return("Successfully sold " + format_number(cookiesToSell) + " cookies for " + convert_to_currency(totalCoinsEarned) + "!");
shopmenu();
}
if(stm=="back")
{
pool.destroy_sound(alertslot);
pool.destroy_sound(storslot);
storambpool.destroy_sound(storambslot);
stormuspool.destroy_sound(stortrackslot);
speak("You're now exiting the cookie store.");
dlgplay("sounds/store/door_close.ogg");
ambpool.destroy_sound(ambslot);
muspool.destroy_sound(mustrackslot);
ambslot=ambpool.play_stationary_extended("sounds/ambience/"+ambtype+".ogg", true,0,0,ambvolume,ambpitch,false);
mustrackslot=muspool.play_stationary_extended("sounds/ambience/"+mustype+".ogg", true,0,0,musvolume,muspitch,false);
form.reset();
clickergame();
}
}
void lottery_buy_menu()
{
    lottery_ticket_category[] visibleCats;
    for (uint i = 0; i < loadedTicketCategories.length(); i++)
    {
        lottery_ticket_category@ cat = loadedTicketCategories[i];
        if (cat.hidden && int(rank) < cat.min_rank) continue;
        bool hasTickets = false;
        for (uint j = 0; j < loadedTickets.length(); j++)
        {
            if (loadedTickets[j].category_id != cat.id) continue;
            if (loadedTickets[j].hidden && int(rank) < loadedTickets[j].min_rank) continue;
            hasTickets = true;
            break;
        }
        if (!hasTickets) continue;
        visibleCats.insert_last(cat);
    }
    if (visibleCats.length() == 0)
    {
        dlg_buffer("No ticket categories are available yet.");
        return;
    }
    string lottery_last_cat_id = "";
    string lottery_last_ticket_id = "";
    while (true)
    {
        setupmenu(false);
        for (uint i = 0; i < visibleCats.length(); i++)
        {
            bool locked = (int(rank) < visibleCats[i].min_rank);
            if (locked)
            {
                if (visibleCats[i].hidden || !show_locked_shops) continue;
                string label = visibleCats[i].name + ". Unlocked at rank " + string(visibleCats[i].min_rank) + ".";
                if (visibleCats[i].description != "") label += " Description: " + visibleCats[i].description;
                m.add_item(label, "locked" + string(i));
            }
            else
            {
                int totalTickets = 0;
                int affordableTickets = 0;
                for (uint j = 0; j < loadedTickets.length(); j++)
                {
                    if (loadedTickets[j].category_id != visibleCats[i].id) continue;
                    if (loadedTickets[j].hidden && int(rank) < loadedTickets[j].min_rank) continue;
                    totalTickets++;
                    if (int(rank) < loadedTickets[j].min_rank) continue;
                    if (lotteryMaxTickets > 0 && loadedTickets[j].owned >= lotteryMaxTickets) continue;
                    double cost = get_ticket_current_cost(loadedTickets[j]);
                    if (coins >= cost) affordableTickets++;
                }
                string itemWord = (totalTickets == 1) ? "ticket" : "tickets";
                string label = visibleCats[i].name + ". Contains " + string(affordableTickets) + " out of " + string(totalTickets) + " purchasable " + itemWord + ".";
                if (visibleCats[i].description != "") label += " Description: " + visibleCats[i].description;
                m.add_item(label, "cat" + string(i));
            }
        }
        m.add_item("Back", "back");
        m.intro_text = "Tickets menu. Please choose a category to browse.";
        int start = 0;
        if (lottery_last_cat_id != "")
        {
            int found = m.find_item_by_id(lottery_last_cat_id);
            if (found != -1) start = found;
        }
        int res = m.run(start, true);
        if (res == -1) return;
        string sel = m.get_item_id(res);
        if (sel == "back") return;
        lottery_last_cat_id = sel;
        if (sel.substr(0, 6) == "locked")
        {
            int idx = string_to_int(sel.substr(6));
            pool.play_stationary("sounds/store/error.ogg", false);
            dlgmessage_return("This category is locked. You need to reach rank " + string(visibleCats[idx].min_rank) + " to access it.");
            continue;
        }
        int catIndex = string_to_int(sel.substr(3));
        lottery_ticket_category@ cat = visibleCats[catIndex];
        int[] catTicketIndices;
        for (uint i = 0; i < loadedTickets.length(); i++)
        {
            if (loadedTickets[i].category_id != cat.id) continue;
            if (loadedTickets[i].hidden && int(rank) < loadedTickets[i].min_rank) continue;
            catTicketIndices.insert_last(int(i));
        }
        while (true)
        {
            setupmenu(false);
            for (uint i = 0; i < catTicketIndices.length(); i++)
            {
                lottery_ticket_item@ t = loadedTickets[catTicketIndices[i]];
                bool locked = (int(rank) < t.min_rank);
                if (locked && !show_locked_shops) continue;
                double cost = get_ticket_current_cost(@t);
                string label = t.name + ", costs " + convert_to_currency(cost) + ".";
                if (locked)
                {
                    label += " Unlocked at rank " + string(t.min_rank) + ".";
                }
                else if (lotteryMaxTickets > 0 && t.owned >= lotteryMaxTickets)
                {
                    label += " Inventory full.";
                }
                else
                {
                    double canBuy = 0;
                    if (lotteryMaxTickets > 0)
                        canBuy = min(double(lotteryMaxTickets) - t.owned, floor(coins / cost));
                    else
                        canBuy = floor(coins / cost);
                    label += " You can buy " + string(canBuy) + ".";
                }
                if (t.description != "") label += " Description: " + t.description;
                m.add_item(label, "ticket" + string(i));
            }
            m.add_item("Back", "back2");
            m.intro_text = cat.name + ".";
            int tstart = 0;
            if (lottery_last_ticket_id != "")
            {
                int found = m.find_item_by_id(lottery_last_ticket_id);
                if (found != -1) tstart = found;
            }
            int tres = m.run(tstart, true);
            if (tres == -1) break;
            string tsel = m.get_item_id(tres);
            lottery_last_ticket_id = tsel;
            if (tsel == "back2") break;
            int ticketCatIdx = string_to_int(tsel.substr(6));
            int ticketIdx = catTicketIndices[ticketCatIdx];
            if (ticketIdx == -1) continue;
            lottery_ticket_item@ ticket = loadedTickets[ticketIdx];
            if (int(rank) < ticket.min_rank)
            {
                pool.play_stationary("sounds/store/error.ogg", false);
                dlgmessage_return("This ticket is locked. You need to reach rank " + string(ticket.min_rank) + " to buy it.");
                continue;
            }
            if (lotteryMaxTickets > 0 && ticket.owned >= lotteryMaxTickets)
            {
                pool.play_stationary("sounds/store/error.ogg", false);
                dlgmessage_return("Your inventory is full. You can hold a maximum of " + string(lotteryMaxTickets) + ". Scratch some first!");
                continue;
            }
            double cost = get_ticket_current_cost(@ticket);
            double maxCanBuy = 0;
            if (lotteryMaxTickets > 0)
                maxCanBuy = min(double(lotteryMaxTickets) - ticket.owned, floor(coins / cost));
            else
                maxCanBuy = floor(coins / cost);
            vd.set_disallowed_chars("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ !@#$%^&*()[]{};:'\"\\|,.<>?/+-=`~_", false, "This character is not allowed.");
            string qInput = vd.input_box("", "How many " + ticket.name + "s would you like to buy? Press enter to buy the maximum amount.", string(maxCanBuy > 0 ? maxCanBuy : 1));
            double qty = string_to_number(qInput);
            if (qty <= 0)
            {
                pool.play_stationary("sounds/store/error.ogg", false);
                dlgmessage_return("Please enter a valid number to buy.");
                continue;
            }
            double totalCost = cost * qty;
            if (coins < totalCost)
            {
                pool.play_stationary("sounds/store/error.ogg", false);
                dlgmessage_return("Error! You can't afford " + format_number(qty) + " " + ticket.name + (qty != 1 ? "s" : "") + "!");
                continue;
            }
            if (lotteryMaxTickets > 0 && ticket.owned + qty > double(lotteryMaxTickets))
            {
                pool.play_stationary("sounds/store/error.ogg", false);
                dlgmessage_return("You can only hold " + string(lotteryMaxTickets) + " tickets of this type. You currently have " + format_number(ticket.owned) + ".");
                continue;
            }
            coins -= totalCost;
            coins = floor(coins);
            stat_coins_spent += totalCost;
            loadedTickets[ticketIdx].owned += qty;
            stat_lottery_tickets_bought += qty;
            pool.play_stationary("sounds/store/buy" + random(1, 4) + ".ogg", false);
            pool.play_stationary("sounds/store/order.ogg", false);
            string plural = (qty == 1) ? "" : "s";
            string ownedPlural = (loadedTickets[ticketIdx].owned == 1) ? "" : "s";
            dlgmessage_return("You bought " + format_number(qty) + " " + ticket.name + plural + " for " + convert_to_currency(totalCost) + ". You now have " + format_number(loadedTickets[ticketIdx].owned) + " " + ticket.name + ownedPlural + " in your inventory.");
        }
    }
}

void prestige_store_menu()
{
    prestige_store_item[] items;
    prestige_menu_def[] menus;
    parse_prestige_store("data/config/stores/prestige.store", items, menus);
    if (items.length() == 0)
    {
        dlgmessage_return("Error! Could not load the prestige store items.");
        questsmenu();
        return;
    }
    bool anyLeft = false;
    for (uint i = 0; i < items.length(); i++)
    {
        if (prestigeLevel < items[i].min_level) continue;
        bool alreadyBought = false;
        for (uint k = 0; k < prestigePurchased.length(); k++)
        {
            if (prestigePurchased[k] == items[i].item_id) { alreadyBought = true; break; }
        }
        if (!alreadyBought) { anyLeft = true; break; }
    }
    if (!anyLeft)
    {
        dlgmessage_return("You have purchased every available upgrade in the prestige store. Keep prestiging to unlock more.");
        questsmenu();
        return;
    }
    setupmenu2();
    for (uint i = 0; i < menus.length(); i++)
    {
        if (menus[i].min_level > 0 && prestigeLevel < menus[i].min_level)
        {
            if (menus[i].hidden || !show_locked_shops) continue;
            string label = menus[i].name + ". Unlocked at prestige level " + string(menus[i].min_level) + ".";
            if (menus[i].description != "")
                label += " Description: " + menus[i].description;
            m.add_item(label, "locked" + string(i));
        }
        else
        {
            int totalItems = 0;
            int affordableItems = 0;
            for (uint j = 0; j < items.length(); j++)
            {
                if (items[j].menu != menus[i].name) continue;
                if (items[j].hidden && prestigeLevel < items[j].min_level) continue;
                bool alreadyBought = false;
                for (uint k = 0; k < prestigePurchased.length(); k++)
                {
                    if (prestigePurchased[k] == items[j].item_id) { alreadyBought = true; break; }
                }
                if (alreadyBought) continue;
                totalItems++;
                if (prestigeLevel < items[j].min_level) continue;
                if (prestige_points >= items[j].cost)
                    affordableItems++;
            }
            string itemWord = (totalItems == 1) ? "item" : "items";
            string label = menus[i].name + ". Contains " + string(affordableItems) + " out of " + string(totalItems) + " purchasable " + itemWord + ".";
            if (menus[i].description != "")
                label += " Description: " + menus[i].description;
            m.add_item(label, "cat" + string(i));
        }
    }
    m.add_item("back", "back");
    string pointWord = (prestige_points == 1) ? "point" : "points";
    m.intro_text = "Prestige store. Please choose a category to brows. You have " + string(prestige_points) + " prestige " + pointWord + " available to spend.";
    int mres = m.run(0, true);
    string sel = m.get_item_id(mres);
    if (mres == -1 || sel == "back")
    {
        questsmenu();
        return;
    }
    if (sel.substr(0, 6) == "locked")
    {
        int idx = string_to_int(sel.substr(6));
        pool.play_stationary("sounds/store/error.ogg", false);
        dlgmessage_return("This category is locked. You need to reach prestige level " + string(menus[idx].min_level) + " to access it.");
        prestige_store_menu();
        return;
    }
    int catIndex = string_to_int(sel.substr(3));
    string chosenMenu = menus[catIndex].name;
    prestige_store_category_menu(items, chosenMenu);
}
void prestige_store_category_menu(prestige_store_item[]@ items, string chosenMenu)
{
    bool anyAvailable = false;
    for (uint i = 0; i < items.length(); i++)
    {
        if (items[i].menu != chosenMenu) continue;
        bool alreadyBought = false;
        for (uint k = 0; k < prestigePurchased.length(); k++)
        {
            if (prestigePurchased[k] == items[i].item_id) { alreadyBought = true; break; }
        }
        if (!alreadyBought) { anyAvailable = true; break; }
    }
    if (!anyAvailable)
    {
        pool.play_stationary("sounds/store/error.ogg", false);
        dlgmessage_return("You have purchased all available upgrades in this category.");
        prestige_store_menu();
        return;
    }
    setupmenu2();
    for (uint i = 0; i < items.length(); i++)
    {
        if (items[i].menu != chosenMenu) continue;
        bool alreadyBought = false;
        for (uint k = 0; k < prestigePurchased.length(); k++)
        {
            if (prestigePurchased[k] == items[i].item_id) { alreadyBought = true; break; }
        }
        if (alreadyBought) continue;
        if (prestigeLevel < items[i].min_level)
        {
            if (items[i].hidden || !show_locked_shops) continue;
            m.add_item(items[i].item_id + ". Unlocked at prestige level " + string(items[i].min_level) + ". Description: " + items[i].description, "locked" + string(i));
            continue;
        }
        string pointWord = (items[i].cost == 1) ? "point" : "points";
        m.add_item(string_replace(items[i].item_id, "_", " ", true) + ", costs " + string(items[i].cost) + " prestige " + pointWord + ". Description: " + items[i].description, "item" + string(i));
    }
    m.add_item("back", "back");
    m.intro_text = chosenMenu + ".";
    int mres = m.run(0, true);
    string sel = m.get_item_id(mres);
    if (mres == -1 || sel == "back")
    {
        prestige_store_menu();
        return;
    }
    for (uint i = 0; i < items.length(); i++)
    {
        if (sel == "locked" + string(i))
        {
            pool.play_stationary("sounds/store/error.ogg", false);
            dlgmessage_return("This item is locked. You need to reach prestige level " + string(items[i].min_level) + " to purchase it.");
            prestige_store_category_menu(items, chosenMenu);
            return;
        }
        if (sel != "item" + string(i)) continue;
        if (prestige_points < items[i].cost)
        {
            pool.play_stationary("sounds/store/error.ogg", false);
            int shortage = items[i].cost - prestige_points;
            string shortWord = (shortage == 1) ? "point" : "points";
            dlgmessage_return("Error! You can't afford this upgrade. You need " + string(shortage) + " more prestige " + shortWord + ".");
            prestige_store_category_menu(items, chosenMenu);
            return;
        }
        prestige_points -= items[i].cost;
        prestigePurchased.insert_last(items[i].item_id);
        apply_prestige_store_upgrade(items[i].item_id);
        pool.play_stationary("sounds/store/buy" + random(1, 4) + ".ogg", false);
        pool.play_stationary("sounds/store/order.ogg", false);
        string pointWord = (items[i].cost == 1) ? "point" : "points";
        dlgmessage_return("Purchase successful! You bought " + string_replace(items[i].item_id, "_", " ", true) + " for " + string(items[i].cost) + " prestige " + pointWord + ".");
        prestige_store_category_menu(items, chosenMenu);
        return;
    }
}
void buymenu()
{
    setupmenu2();
    m.add_item("bundles", "bundles");
    m.add_item("singles", "singles");
    m.add_item("back", "back");
    m.intro_text = "Upgrades menu. What would you like to browse?";
    int buy_start = 0;
    if (buymenu_last_id != "")
    {
        int found = m.find_item_by_id(buymenu_last_id);
        if (found != -1) buy_start = found;
    }
    int mres = m.run(buy_start, true);
    string sel = m.get_item_id(mres);
    if (mres == -1 || sel == "back")
    {
        buymenu_last_id = "";
        shopmenu();
        return;
    }
    buymenu_last_id = sel;
    if (sel == "singles")
        bakermenu();
    else if (sel == "bundles")
        bundlemenu();
}
void bakermenu()
{
    store_item[] items;
    store_menu[] menus;
    parse_store("data/config/stores/singles.store", items, menus);
    if (items.length() == 0)
    {
        dlgmessage_return("Error! Could not load the baking shop items.");
        shopmenu();
        return;
    }
    setupmenu2();
    for (uint i = 0; i < menus.length(); i++)
    {
        if (menus[i].min_rank > 0 && rank < menus[i].min_rank)
        {
            if (menus[i].hidden || !show_locked_shops) continue;
            string label = menus[i].name + ". Unlocked at rank " + string(menus[i].min_rank) + ".";
            if (menus[i].description != "")
                label += " Description: " + menus[i].description;
            m.add_item(label, "locked" + string(i));
        }
        else
        {
            int totalItems = 0;
            int affordableItems = 0;
            double menuBalance = (menus[i].currency == "cookies") ? cookies : coins;
            for (uint j = 0; j < items.length(); j++)
            {
                if (items[j].menu != menus[i].name) continue;
                totalItems++;
                if (items[j].min_rank > 0 && rank < items[j].min_rank) continue;
                double level = (items[j].target == 2) ? manulcookie_purchases : (items[j].target == 3) ? cookiespeed_purchases : autocookie_purchases;
                double cost = buy_item(level, items[j].base_cost, items[j].cost_multiplier);
                if (menuBalance >= cost)
                    affordableItems++;
            }
            string itemWord = (totalItems == 1) ? "item" : "items";
            string label = menus[i].name + ". Uses " + (menus[i].currency == "cookies" ? "baked cookies" : "money") + ". Contains " + string(affordableItems) + " out of " + string(totalItems) + " purchasable " + itemWord + ".";
            if (menus[i].description != "")
                label += " Description: " + menus[i].description;
            m.add_item(label, "cat" + string(i));
        }
    }
    m.add_item("back", "back");
    m.intro_text = "Singles menu. Please choose a category to browse.";
    int start_pos = 0;
    if (baker_last_cat_id != "")
    {
        int found = m.find_item_by_id(baker_last_cat_id);
        if (found != -1)
            start_pos = found;
    }
    int mres = m.run(start_pos, true);
    string sel = m.get_item_id(mres);
    if (mres != -1)
        baker_last_cat_id = sel;
    if (mres == -1 || sel == "back")
    {
        baker_last_cat_id = "";
        shopmenu();
        return;
    }
    if (sel.substr(0, 6) == "locked")
    {
        int idx = string_to_int(sel.substr(6));
        pool.play_stationary("sounds/store/error.ogg", false);
        dlgmessage_return("This category is locked. You need to reach rank " + string(menus[idx].min_rank) + " to access it.");
        bakermenu();
        return;
    }
    int catIndex = string_to_int(sel.substr(3));
    string chosenMenu = menus[catIndex].name;
    string chosenCurrency = menus[catIndex].currency;
    bakercategorymenu(items, chosenMenu, chosenCurrency);
}
void bakercategorymenu(store_item[]@ items, string chosenMenu, string chosenCurrency)
{
    while (true)
    {
    double balance = (chosenCurrency == "cookies") ? cookies : coins;
    setupmenu2();
    for (uint i = 0; i < items.length(); i++)
    {
        if (items[i].menu != chosenMenu) continue;
        if (items[i].min_rank > 0 && rank < items[i].min_rank)
        {
            if (items[i].hidden || !show_locked_shops) continue;
            m.add_item(items[i].item_type + ". Unlocked at rank " + string(items[i].min_rank) + ". Description: " + items[i].description, "locked" + string(i));
            continue;
        }
        double level = (items[i].target == 2) ? manulcookie_purchases : (items[i].target == 3) ? cookiespeed_purchases : autocookie_purchases;
        double cost = buy_item(level, items[i].base_cost, items[i].cost_multiplier);
        double maxbuy = calc_max_buyable(balance, level, items[i].base_cost, items[i].cost_multiplier);
        string costStr = (chosenCurrency == "cookies") ? format_number(cost) + " baked cookies" : convert_to_currency(cost);
        m.add_item(items[i].item_type + ", costs " + costStr + ". You can buy " + format_number(maxbuy) + ". Description: " + items[i].description, "item" + string(i));
    }
    bool anyAffordable = false;
    for (uint i = 0; i < items.length(); i++)
    {
        if (items[i].menu != chosenMenu) continue;
        if (items[i].min_rank > 0 && rank < items[i].min_rank) continue;
        double level = (items[i].target == 2) ? manulcookie_purchases : (items[i].target == 3) ? cookiespeed_purchases : autocookie_purchases;
        double maxbuy = calc_max_buyable(balance, level, items[i].base_cost, items[i].cost_multiplier);
        if (maxbuy >= 1) { anyAffordable = true; break; }
    }
    if (anyAffordable)
        m.add_item("Buy all affordable items", "buyall");
    m.add_item("back", "back");
    m.intro_text = chosenMenu + ".";
    int start_pos = 0;
    if (baker_last_item_id != "")
    {
        int found = m.find_item_by_id(baker_last_item_id);
        if (found != -1)
            start_pos = found;
    }
    int mres = m.run(start_pos, true);
    string sel = m.get_item_id(mres);
    if (mres != -1)
        baker_last_item_id = sel;
    if (mres == -1 || sel == "back")
    {
        baker_last_item_id = "";
        bakermenu();
        return;
    }
    if (sel == "buyall")
    {
        double overallMax = 0;
        for (uint i = 0; i < items.length(); i++)
        {
            if (items[i].menu != chosenMenu) continue;
            if (items[i].min_rank > 0 && rank < items[i].min_rank) continue;
            double level = (items[i].target == 2) ? manulcookie_purchases : (items[i].target == 3) ? cookiespeed_purchases : autocookie_purchases;
            double maxbuy = calc_max_buyable(balance, level, items[i].base_cost, items[i].cost_multiplier);
            if (maxbuy > overallMax) overallMax = maxbuy;
        }
        vd.set_disallowed_chars("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ !@#$%^&*()[]{};:'\"\\|,.<>?/+-=`~_", false, "This character is not allowed.");
        string bulkInput = vd.input_box("", "How many of each item would you like to buy? Press enter to buy the maximum amount.", string(round(overallMax, 0)));
        double bulkQuantity = string_to_number(bulkInput);
        if (bulkQuantity <= 0)
        {
            pool.destroy_sound(alertslot);
            pool.play_stationary("sounds/store/error.ogg", false);
            dlgmessage_return("Error! Please enter a valid number to buy!");
            continue;
        }
        double totalSpent = 0;
        double autoGained = 0, manulGained = 0, speedGained = 0;
        double autoPercentGained = 0, manulPercentGained = 0, speedPercentGained = 0;
        for (uint i = 0; i < items.length(); i++)
        {
            if (items[i].menu != chosenMenu) continue;
            if (items[i].min_rank > 0 && rank < items[i].min_rank) continue;
            double level = (items[i].target == 2) ? manulcookie_purchases : (items[i].target == 3) ? cookiespeed_purchases : autocookie_purchases;
            double maxbuy = calc_max_buyable(balance, level, items[i].base_cost, items[i].cost_multiplier);
            if (maxbuy < 1) continue;
            double quantity = (bulkQuantity < maxbuy) ? bulkQuantity : maxbuy;
            double totalCost = calc_total_upgrade_cost(level, quantity, items[i].base_cost, items[i].cost_multiplier);
            if (chosenCurrency == "cookies") { cookies -= totalCost; } else { coins -= totalCost; stat_coins_spent += totalCost; }
            totalSpent += totalCost;
            if (items[i].target == 1)
            {
                if (items[i].use_percent)
                {
                    double gained = (autocookie * (items[i].amount / 100.0)) * quantity;
                    autocookie += gained;
                    autoPercentGained += items[i].amount * quantity;
                }
                else
                {
                    autocookie += quantity * items[i].amount;
                    autoGained += quantity * items[i].amount;
                }
                autocookie_purchases += quantity;
            }
            else if (items[i].target == 2)
            {
                if (items[i].use_percent)
                {
                    double gained = (manulcookie * (items[i].amount / 100.0)) * quantity;
                    manulcookie += gained;
                    manulPercentGained += items[i].amount * quantity;
                }
                else
                {
                    manulcookie += quantity * items[i].amount;
                    manulGained += quantity * items[i].amount;
                }
                manulcookie_purchases += quantity;
            }
            else if (items[i].target == 3)
            {
                if (items[i].use_percent)
                {
                    double gained = (cookiespeed * (items[i].amount / 100.0)) * quantity;
                    cookiespeed += gained;
                    clicktime -= gained;
                    speedPercentGained += items[i].amount * quantity;
                }
                else
                {
                    cookiespeed += quantity * items[i].amount;
                    clicktime -= cookiespeed;
                    speedGained += quantity * items[i].amount;
                }
                cookiespeed_purchases += quantity;
            }
        }
        if (totalSpent > 0)
        {
            string log = "";
            string[] logParts;
            if (autoGained > 0) logParts.insert_last(format_number(autoGained) + " auto " + (autoGained == 1 ? "cookie" : "cookies"));
            if (autoPercentGained > 0) logParts.insert_last(format_number(autoPercentGained) + "% auto cookies");
            if (manulGained > 0) logParts.insert_last(format_number(manulGained) + " manual " + (manulGained == 1 ? "cookie" : "cookies"));
            if (manulPercentGained > 0) logParts.insert_last(format_number(manulPercentGained) + "% manual cookies");
            if (speedGained > 0) logParts.insert_last(format_number(speedGained) + "ms of baking speed");
            if (speedPercentGained > 0) logParts.insert_last(format_number(speedPercentGained) + "% baking speed");
            if (logParts.length() == 1) log = logParts[0];
            else if (logParts.length() == 2) log = logParts[0] + ", and " + logParts[1];
            else { for (uint li = 0; li < logParts.length() - 1; li++) { if (log != "") log += ", "; log += logParts[li]; } log += ", and " + logParts[logParts.length() - 1]; }
            pool.play_stationary("sounds/store/buy" + random(1, 4) + ".ogg", false);
            pool.play_stationary("sounds/store/order.ogg", false);
            stat_singles_purchased++;
            string spentStr = (chosenCurrency == "cookies") ? format_number(totalSpent) + " baked cookies" : convert_to_currency(totalSpent);
            dlgmessage_return("Bulk purchase complete! You gained " + log + " for a total of " + spentStr + ".");
        }
        else
            speak("Nothing affordable to buy.");
        continue;
    }
    for (uint i = 0; i < items.length(); i++)
    {
        if (sel == "locked" + string(i))
        {
            pool.play_stationary("sounds/store/error.ogg", false);
            dlgmessage_return("This item is locked. You need to reach rank " + string(items[i].min_rank) + " to purchase it.");
            break;
        }
        if (sel != "item" + string(i)) continue;
        double level = (items[i].target == 2) ? manulcookie_purchases : (items[i].target == 3) ? cookiespeed_purchases : autocookie_purchases;
        double maxbuy = calc_max_buyable(balance, level, items[i].base_cost, items[i].cost_multiplier);
        vd.set_disallowed_chars("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ !@#$%^&*()[]{};:'\"\\|,.<>?/+-=`~_", false, "This character is not allowed.");
        string promptName = string_replace(items[i].item_type, "_", " ", true);
        string promptPlural;
        if (promptName.length() > 0 && promptName.substr(promptName.length() - 1) == "y")
            promptPlural = promptName.substr(0, promptName.length() - 1) + "ies";
        else if (promptName.length() > 0 && promptName.substr(promptName.length() - 1) == "s")
            promptPlural = promptName;
        else
            promptPlural = promptName + "s";
        string input = vd.input_box("", "How many " + promptPlural + " would you like to buy? Press enter to buy the maximum amount.", string(round(maxbuy, 0)));
        double quantity = string_to_number(input);
        if (quantity <= 0)
        {
            pool.destroy_sound(alertslot);
            pool.play_stationary("sounds/store/error.ogg", false);
            dlgmessage_return("Error! Please enter a valid number to buy!");
            break;
        }
        double totalCost = calc_total_upgrade_cost(level, quantity, items[i].base_cost, items[i].cost_multiplier);
        if (balance >= totalCost)
        {
            if (chosenCurrency == "cookies") { cookies -= totalCost; } else { coins -= totalCost; stat_coins_spent += totalCost; }
            if (items[i].target == 1)
            {
                if (items[i].use_percent)
                    autocookie += (autocookie * (items[i].amount / 100.0)) * quantity;
                else
                    autocookie += quantity * items[i].amount;
                autocookie_purchases += quantity;
            }
            else if (items[i].target == 2)
            {
                if (items[i].use_percent)
                    manulcookie += (manulcookie * (items[i].amount / 100.0)) * quantity;
                else
                    manulcookie += quantity * items[i].amount;
                manulcookie_purchases += quantity;
            }
            else if (items[i].target == 3)
            {
                if (items[i].use_percent)
                {
                    double gained = (cookiespeed * (items[i].amount / 100.0)) * quantity;
                    cookiespeed += gained;
                    clicktime -= gained;
                }
                else
                {
                    cookiespeed += quantity * items[i].amount;
                    clicktime -= cookiespeed;
                }
                cookiespeed_purchases += quantity;
            }
            double nextCost = buy_item(level + quantity, items[i].base_cost, items[i].cost_multiplier);
            pool.play_stationary("sounds/store/buy" + random(1, 4) + ".ogg", false);
            pool.play_stationary("sounds/store/order.ogg", false);
            string itemName = string_replace(items[i].item_type, "_", " ", true);
            string itemWord;
            if (quantity == 1)
                itemWord = itemName;
            else if (itemName.length() > 0 && itemName.substr(itemName.length() - 1) == "y")
                itemWord = itemName.substr(0, itemName.length() - 1) + "ies";
            else
                itemWord = itemName + "s";
            stat_singles_purchased++;
            string costStr = (chosenCurrency == "cookies") ? format_number(totalCost) + " baked cookies" : convert_to_currency(totalCost);
            string nextStr = (chosenCurrency == "cookies") ? format_number(nextCost) + " baked cookies" : convert_to_currency(nextCost);
            dlgmessage_return("Purchase successful! You bought " + format_number(quantity) + " " + itemWord + " for " + costStr + ". Next upgrade will cost " + nextStr + ".");
        }
        else
        {
            pool.play_stationary("sounds/store/error.ogg", false);
            string errName = string_replace(items[i].item_type, "_", " ", true);
            string errWord;
            if (quantity == 1)
                errWord = errName;
            else if (errName.length() > 0 && errName.substr(errName.length() - 1) == "y")
                errWord = errName.substr(0, errName.length() - 1) + "ies";
            else if (errName.length() > 0 && errName.substr(errName.length() - 1) == "s")
                errWord = errName;
            else
                errWord = errName + "s";
            dlgmessage_return("Error! You can't afford " + format_number(quantity) + " " + errWord + "!");
        }
        break;
    }
    }
}
void bundlemenu()
{
    bundle_item[] bundles;
    bundle_menu[] menus;
    store_item[] storeItems;
    store_menu[] storeMenus;
    parse_bundles("data/config/stores/bundles.store", bundles, menus);
    parse_store("data/config/stores/singles.store", storeItems, storeMenus);
    setupmenu2();
    for (uint i = 0; i < menus.length(); i++)
    {
        if (menus[i].min_rank > 0 && rank < menus[i].min_rank)
        {
            if (menus[i].hidden || !show_locked_shops) continue;
            string label = menus[i].name + ". Unlocked at rank " + string(menus[i].min_rank) + ".";
            if (menus[i].description != "")
                label += " Description: " + menus[i].description;
            m.add_item(label, "locked" + string(i));
        }
        else
        {
            int totalBundles = 0;
            int affordableBundles = 0;
            for (uint j = 0; j < bundles.length(); j++)
            {
                if (bundles[j].menu != menus[i].name) continue;
                totalBundles++;
                if (bundles[j].min_rank > 0 && rank < bundles[j].min_rank) continue;
                double totalCost = 0;
                for (uint k = 0; k < bundles[j].entries.length(); k++)
                {
                    for (uint l = 0; l < storeItems.length(); l++)
                    {
                        if (storeItems[l].item_type == bundles[j].entries[k].item_type)
                        {
                            double level = (storeItems[l].target == 2) ? manulcookie_purchases : (storeItems[l].target == 3) ? cookiespeed_purchases : autocookie_purchases;
                            totalCost += calc_total_upgrade_cost(level, bundles[j].entries[k].quantity, storeItems[l].base_cost, storeItems[l].cost_multiplier);
                            break;
                        }
                    }
                }
                double bundleMenuBalance = (menus[i].currency == "cookies") ? cookies : coins;
                if (bundleMenuBalance >= totalCost)
                    affordableBundles++;
            }
            string bundleWord = (totalBundles == 1) ? "bundle" : "bundles";
            string label = menus[i].name + ". Uses " + (menus[i].currency == "cookies" ? "baked cookies" : "money") + ". Contains " + string(affordableBundles) + " out of " + string(totalBundles) + " purchasable " + bundleWord + ".";
            if (menus[i].description != "")
                label += " Description: " + menus[i].description;
            m.add_item(label, "cat" + string(i));
        }
    }
    m.add_item("back", "back");
    m.intro_text = "Bundles menu. Please choose a category to browse.";
    int start_pos = 0;
    if (bundle_last_cat_id != "")
    {
        int found = m.find_item_by_id(bundle_last_cat_id);
        if (found != -1)
            start_pos = found;
    }
    int mres = m.run(start_pos, true);
    string sel = m.get_item_id(mres);
    if (mres != -1)
        bundle_last_cat_id = sel;
    if (mres == -1 || sel == "back")
    {
        bundle_last_cat_id = "";
        buymenu();
        return;
    }
    if (sel.substr(0, 6) == "locked")
    {
        int idx = string_to_int(sel.substr(6));
        pool.play_stationary("sounds/store/error.ogg", false);
        dlgmessage_return("This category is locked. You need to reach rank " + string(menus[idx].min_rank) + " to access it.");
        bundlemenu();
        return;
    }
    int catIndex = string_to_int(sel.substr(3));
    bundlecategorymenu(bundles, menus[catIndex].name, menus[catIndex].currency, storeItems);
}
void bundlecategorymenu(bundle_item[]@ bundles, string chosenMenu, string chosenCurrency, store_item[]@ storeItems)
{
    while (true)
    {
    double balance = (chosenCurrency == "cookies") ? cookies : coins;
    setupmenu2();
    for (uint i = 0; i < bundles.length(); i++)
    {
        if (bundles[i].menu != chosenMenu) continue;
        if (bundles[i].min_rank > 0 && rank < bundles[i].min_rank)
        {
            if (bundles[i].hidden || !show_locked_shops) continue;
            m.add_item(bundles[i].name + ". Unlocked at rank " + string(bundles[i].min_rank) + ". Description: " + bundles[i].description, "locked" + string(i));
            continue;
        }
        double totalCost = 0;
        for (uint j = 0; j < bundles[i].entries.length(); j++)
        {
            for (uint k = 0; k < storeItems.length(); k++)
            {
                if (storeItems[k].item_type == bundles[i].entries[j].item_type)
                {
                    double level = (storeItems[k].target == 2) ? manulcookie_purchases : (storeItems[k].target == 3) ? cookiespeed_purchases : autocookie_purchases;
                    totalCost += calc_total_upgrade_cost(level, bundles[i].entries[j].quantity, storeItems[k].base_cost, storeItems[k].cost_multiplier);
                    break;
                }
            }
        }
        double canAfford = (totalCost > 0) ? floor(balance / totalCost) : 0;
        string costStr = (chosenCurrency == "cookies") ? format_number(totalCost) + " baked cookies" : convert_to_currency(totalCost);
        m.add_item(bundles[i].name + ". Costs " + costStr + ". You can buy " + format_number(canAfford) + ". Description: " + bundles[i].description, "bundle" + string(i));
    }
    bool anyBundleAffordable = false;
    for (uint i = 0; i < bundles.length(); i++)
    {
        if (bundles[i].menu != chosenMenu) continue;
        if (bundles[i].min_rank > 0 && rank < bundles[i].min_rank) continue;
        double totalCost = 0;
        for (uint j = 0; j < bundles[i].entries.length(); j++)
        {
            for (uint k = 0; k < storeItems.length(); k++)
            {
                if (storeItems[k].item_type == bundles[i].entries[j].item_type)
                {
                    double level = (storeItems[k].target == 2) ? manulcookie_purchases : (storeItems[k].target == 3) ? cookiespeed_purchases : autocookie_purchases;
                    totalCost += calc_total_upgrade_cost(level, bundles[i].entries[j].quantity, storeItems[k].base_cost, storeItems[k].cost_multiplier);
                    break;
                }
            }
        }
        if (balance >= totalCost) { anyBundleAffordable = true; break; }
    }
    if (anyBundleAffordable)
        m.add_item("Buy one of every affordable bundle", "buyallbundles");
    m.add_item("back", "back");
    m.intro_text = chosenMenu + ".";
    int start_pos = 0;
    if (bundle_last_item_id != "")
    {
        int found = m.find_item_by_id(bundle_last_item_id);
        if (found != -1)
            start_pos = found;
    }
    int mres = m.run(start_pos, true);
    string sel = m.get_item_id(mres);
    if (mres != -1)
        bundle_last_item_id = sel;
    if (mres == -1 || sel == "back")
    {
        bundle_last_item_id = "";
        bundlemenu();
        return;
    }
    if (sel == "buyallbundles")
    {
        double onePassCost = 0;
        for (uint i = 0; i < bundles.length(); i++)
        {
            if (bundles[i].menu != chosenMenu) continue;
            if (bundles[i].min_rank > 0 && rank < bundles[i].min_rank) continue;
            double totalCost = 0;
            for (uint j = 0; j < bundles[i].entries.length(); j++)
            {
                for (uint k = 0; k < storeItems.length(); k++)
                {
                    if (storeItems[k].item_type == bundles[i].entries[j].item_type)
                    {
                        double level = (storeItems[k].target == 2) ? manulcookie_purchases : (storeItems[k].target == 3) ? cookiespeed_purchases : autocookie_purchases;
                        totalCost += calc_total_upgrade_cost(level, bundles[i].entries[j].quantity, storeItems[k].base_cost, storeItems[k].cost_multiplier);
                        break;
                    }
                }
            }
            if (balance >= totalCost)
                onePassCost += totalCost;
        }
        int maxPasses = (onePassCost > 0) ? int(floor(balance / onePassCost)) : 1;
        if (maxPasses < 1) maxPasses = 1;
        string qInput = vd.input_box("", "How many of each affordable bundle would you like to buy? Press enter to buy the maximum amount.", string(maxPasses));
        if (qInput == "") { continue; }
        int passes = string_to_int(qInput);
        if (passes < 1) { pool.play_stationary("sounds/store/error.ogg", false); dlgmessage_return("Please enter a number greater than zero. Press enter or space to continue."); continue; }
        double totalSpent = 0;
        double autoGained = 0, manulGained = 0, speedGained = 0;
        string[] boughtNames;
        for (int pass = 0; pass < passes; pass++)
        {
            for (uint i = 0; i < bundles.length(); i++)
            {
                if (bundles[i].menu != chosenMenu) continue;
                if (bundles[i].min_rank > 0 && rank < bundles[i].min_rank) continue;
                double totalCost = 0;
                for (uint j = 0; j < bundles[i].entries.length(); j++)
                {
                    for (uint k = 0; k < storeItems.length(); k++)
                    {
                        if (storeItems[k].item_type == bundles[i].entries[j].item_type)
                        {
                            double level = (storeItems[k].target == 2) ? manulcookie_purchases : (storeItems[k].target == 3) ? cookiespeed_purchases : autocookie_purchases;
                            totalCost += calc_total_upgrade_cost(level, bundles[i].entries[j].quantity, storeItems[k].base_cost, storeItems[k].cost_multiplier);
                            break;
                        }
                    }
                }
                double passBalance = (chosenCurrency == "cookies") ? cookies : coins;
                if (passBalance < totalCost) continue;
                if (chosenCurrency == "cookies") { cookies -= totalCost; } else { coins -= totalCost; stat_coins_spent += totalCost; }
                totalSpent += totalCost;
                if (pass == 0) boughtNames.insert_last(bundles[i].name);
                for (uint j = 0; j < bundles[i].entries.length(); j++)
                {
                    for (uint k = 0; k < storeItems.length(); k++)
                    {
                        if (storeItems[k].item_type == bundles[i].entries[j].item_type)
                        {
                            double amount = bundles[i].entries[j].quantity;
                            if (storeItems[k].target == 1) { autocookie += amount * storeItems[k].amount; autocookie_purchases += amount; autoGained += amount * storeItems[k].amount; }
                            else if (storeItems[k].target == 2) { manulcookie += amount * storeItems[k].amount; manulcookie_purchases += amount; manulGained += amount * storeItems[k].amount; }
                            else if (storeItems[k].target == 3) { cookiespeed += amount * storeItems[k].amount; clicktime -= amount * storeItems[k].amount; cookiespeed_purchases += amount; speedGained += amount * storeItems[k].amount; }
                            break;
                        }
                    }
                }
                stat_bundles_purchased++;
            }
        }
        if (totalSpent > 0)
        {
            string gainLog = "";
            string[] gainParts;
            if (autoGained > 0) gainParts.insert_last(format_number(autoGained) + " auto " + (autoGained == 1 ? "cookie" : "cookies"));
            if (manulGained > 0) gainParts.insert_last(format_number(manulGained) + " manual " + (manulGained == 1 ? "cookie" : "cookies"));
            if (speedGained > 0) gainParts.insert_last(format_number(speedGained) + "ms of baking speed");
            if (gainParts.length() == 1) gainLog = gainParts[0];
            else if (gainParts.length() == 2) gainLog = gainParts[0] + ", and " + gainParts[1];
            else { for (uint li = 0; li < gainParts.length() - 1; li++) { if (gainLog != "") gainLog += ", "; gainLog += gainParts[li]; } gainLog += ", and " + gainParts[gainParts.length() - 1]; }
            string boughtLog = "";
            if (boughtNames.length() == 1) boughtLog = boughtNames[0];
            else if (boughtNames.length() == 2) boughtLog = boughtNames[0] + ", and " + boughtNames[1];
            else { for (uint li = 0; li < boughtNames.length() - 1; li++) { if (boughtLog != "") boughtLog += ", "; boughtLog += boughtNames[li]; } boughtLog += ", and " + boughtNames[boughtNames.length() - 1]; }
            pool.play_stationary("sounds/store/buy" + random(1, 4) + ".ogg", false);
            pool.play_stationary("sounds/store/order.ogg", false);
            string spentStr = (chosenCurrency == "cookies") ? format_number(totalSpent) + " baked cookies" : convert_to_currency(totalSpent);
            dlgmessage_return("Bulk purchase complete! You bought " + string(passes) + " of each: " + boughtLog + ". You gained " + gainLog + " for a total of " + spentStr + ".");
        }
        else
            speak("Nothing affordable to buy.");
        continue;
    }
    if (sel.substr(0, 6) == "locked")
    {
        int idx = string_to_int(sel.substr(6));
        pool.play_stationary("sounds/store/error.ogg", false);
        dlgmessage_return("This bundle is locked. You need to reach rank " + string(bundles[idx].min_rank) + " to purchase it.");
        continue;
    }
    if (sel.substr(0, 6) == "bundle")
    {
        int idx = string_to_int(sel.substr(6));
        double totalCost = 0;
        for (uint j = 0; j < bundles[idx].entries.length(); j++)
        {
            for (uint k = 0; k < storeItems.length(); k++)
            {
                if (storeItems[k].item_type == bundles[idx].entries[j].item_type)
                {
                    double level = (storeItems[k].target == 2) ? manulcookie_purchases : (storeItems[k].target == 3) ? cookiespeed_purchases : autocookie_purchases;
                    totalCost += calc_total_upgrade_cost(level, bundles[idx].entries[j].quantity, storeItems[k].base_cost, storeItems[k].cost_multiplier);
                    break;
                }
            }
        }
        vd.set_disallowed_chars("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ !@#$%^&*()[]{};:'\"\\|,.<>?/+-=`~_", false, "This character is not allowed.");
        double maxBundles = (totalCost > 0) ? floor(balance / totalCost) : 0;
        string input = vd.input_box("", "How many " + bundles[idx].name + " would you like to buy? Press enter to buy the maximum amount.", string(maxBundles));
        double qty = string_to_number(input);
        if (qty <= 0)
        {
            pool.destroy_sound(alertslot);
            pool.play_stationary("sounds/store/error.ogg", false);
            dlgmessage_return("Error! Please enter a valid number to buy!");
            continue;
        }
        double grandTotal = totalCost * qty;
        if (balance < grandTotal)
        {
            pool.play_stationary("sounds/store/error.ogg", false);
            dlgmessage_return("Error! You can't afford " + format_number(qty) + " " + bundles[idx].name + (qty != 1 ? "s" : "") + "!");
            continue;
        }
        if (chosenCurrency == "cookies") { cookies -= grandTotal; } else { coins -= grandTotal; stat_coins_spent += grandTotal; }
        string gainLog = "";
        double autoGained = 0, manulGained = 0, speedGained = 0;
        for (uint j = 0; j < bundles[idx].entries.length(); j++)
        {
            for (uint k = 0; k < storeItems.length(); k++)
            {
                if (storeItems[k].item_type == bundles[idx].entries[j].item_type)
                {
                    double amount = bundles[idx].entries[j].quantity * qty;
                    if (storeItems[k].target == 1)
                    {
                        autocookie += amount * storeItems[k].amount;
                        autocookie_purchases += amount;
                        autoGained += amount * storeItems[k].amount;
                    }
                    else if (storeItems[k].target == 2)
                    {
                        manulcookie += amount * storeItems[k].amount;
                        manulcookie_purchases += amount;
                        manulGained += amount * storeItems[k].amount;
                    }
                    else if (storeItems[k].target == 3)
                    {
                        cookiespeed += amount * storeItems[k].amount;
                        clicktime -= amount * storeItems[k].amount;
                        cookiespeed_purchases += amount;
                        speedGained += amount * storeItems[k].amount;
                    }
                    break;
                }
            }
        }
        string[] gainParts;
        if (autoGained > 0) gainParts.insert_last(format_number(autoGained) + " auto " + (autoGained == 1 ? "cookie" : "cookies"));
        if (manulGained > 0) gainParts.insert_last(format_number(manulGained) + " manual " + (manulGained == 1 ? "cookie" : "cookies"));
        if (speedGained > 0) gainParts.insert_last(format_number(speedGained) + "ms of baking speed");
        if (gainParts.length() == 1) gainLog = gainParts[0];
        else if (gainParts.length() == 2) gainLog = gainParts[0] + ", and " + gainParts[1];
        else { for (uint li = 0; li < gainParts.length() - 1; li++) { if (gainLog != "") gainLog += ", "; gainLog += gainParts[li]; } gainLog += ", and " + gainParts[gainParts.length() - 1]; }
        double nextBundleCost = 0;
        for (uint j = 0; j < bundles[idx].entries.length(); j++)
        {
            for (uint k = 0; k < storeItems.length(); k++)
            {
                if (storeItems[k].item_type == bundles[idx].entries[j].item_type)
                {
                    double level = (storeItems[k].target == 2) ? manulcookie_purchases : (storeItems[k].target == 3) ? cookiespeed_purchases : autocookie_purchases;
                    nextBundleCost += calc_total_upgrade_cost(level, bundles[idx].entries[j].quantity, storeItems[k].base_cost, storeItems[k].cost_multiplier);
                    break;
                }
            }
        }
        stat_bundles_purchased++;
        pool.play_stationary("sounds/store/buy" + random(1, 4) + ".ogg", false);
        pool.play_stationary("sounds/store/order.ogg", false);
        string grandStr = (chosenCurrency == "cookies") ? format_number(grandTotal) + " baked cookies" : convert_to_currency(grandTotal);
        string nextBundleStr = (chosenCurrency == "cookies") ? format_number(nextBundleCost) + " baked cookies" : convert_to_currency(nextBundleCost);
        dlgmessage_return("Purchase successful! You bought " + format_number(qty) + " " + bundles[idx].name + (qty != 1 ? "s" : "") + " for " + grandStr + ". You gained " + gainLog + ". Next bundle will cost " + nextBundleStr + ".");
        continue;
    }
    }
}

void add_auto_slots()
{
    setupmenu(false);
    m.add_item("Add 1 slot for "   + convert_to_currency(calc_slot_cost(1)),   "add_slot");
    m.add_item("Add 5 slots for "   + convert_to_currency(calc_slot_cost(5)),   "add_slot2");
    m.add_item("Add 10 slots for "  + convert_to_currency(calc_slot_cost(10)),  "add_slot3");
    m.add_item("Add 25 slots for "  + convert_to_currency(calc_slot_cost(25)),  "add_slot4");
    m.add_item("Add 50 slots for "  + convert_to_currency(calc_slot_cost(50)),  "add_slot5");
    m.add_item("Add 100 slots for " + convert_to_currency(calc_slot_cost(100)), "add_slot6");
    m.add_item("Add 250 slots for " + convert_to_currency(calc_slot_cost(250)), "add_slot7");
    m.add_item("Add 500 slots for " + convert_to_currency(calc_slot_cost(500)), "add_slot8");
m.add_item("Add 1000 slots for " + convert_to_currency(calc_slot_cost(1000)), "add_slot9");
m.add_item("Add 2500 slots for " + convert_to_currency(calc_slot_cost(2500)), "add_slot10");
m.add_item("Add 5000 slots for " + convert_to_currency(calc_slot_cost(5000)), "add_slot11");
m.add_item("Add 10000 slots for " + convert_to_currency(calc_slot_cost(10000)), "add_slot12");
    m.add_item("Back", "back");
    m.intro_text = "Auto slots menu.";
    int start_pos = 0;
    if (last_menu_id != "")
    {
        int found = m.find_item_by_id(last_menu_id);
        if (found != -1)
            start_pos = found;
    }
        int mres2 = m.run(start_pos, true);
        string slotprod = m.get_item_id(mres2);
    if (mres2 != -1)
{
        last_menu_id = slotprod;
}
        if (mres2 == -1 || m.get_item_id(mres2) == "back")
        {
last_menu_id = "";
            auto_slots_menu();
        }
        int count = 0;
        if (slotprod == "add_slot")   count = 1;
        if (slotprod == "add_slot2")  count = 5;
        if (slotprod == "add_slot3")  count = 10;
        if (slotprod == "add_slot4")  count = 25;
        if (slotprod == "add_slot5")  count = 50;
        if (slotprod == "add_slot6")  count = 100;
        if (slotprod == "add_slot7")  count = 250;
        if (slotprod == "add_slot8")  count = 500;
if (slotprod == "add_slot9")  count = 1000;
if (slotprod == "add_slot10")  count = 2500;
if (slotprod == "add_slot11")  count = 5000;
if (slotprod == "add_slot12")  count = 10000;
        if (count > 0)
        {
            double cost = calc_slot_cost(count);
            if (coins >= cost)
            {
                coins -= cost;
                stat_coins_spent += cost;
                for (int i = 0; i < count; i++)
                {
                    baking_slots.insert_last(true);
                    autobakeSlotEnabled.insert_last(false);
                    slotBaseCost *= slotMultiplier;
                }
                stat_auto_slots_purchased += count;
                pool.destroy_sound(alertslot);
                alertslot = pool.play_stationary("sounds/misc/prodslot.ogg", false);
int produced = baking_slots.length();
speak("Added " + string(count) + " slot" + (count == 1 ? "" : "s") + ". You now have " + string(produced) + " produced slot" + (produced == 1 ? "" : "s") + ".");
            add_auto_slots();
            }
            else
            {
                alertslot = pool.play_stationary("sounds/dlg/error.ogg", false);
                dlg("Error! You can't afford " + string(count) + " new slot" + (count == 1 ? "" : "s") + "!");
                pool.destroy_sound(alertslot);
add_auto_slots();
}
}
}
void add_manual_slots()
{
    setupmenu(false);
    m.add_item("Add 1 manual slot for "     + convert_to_currency(calc_slot_cost(1,    manualSlotBaseCost, manualSlotMultiplier)), "add_mslot1");
    m.add_item("Add 5 manual slots for "    + convert_to_currency(calc_slot_cost(5,    manualSlotBaseCost, manualSlotMultiplier)), "add_mslot2");
    m.add_item("Add 10 manual slots for "   + convert_to_currency(calc_slot_cost(10,   manualSlotBaseCost, manualSlotMultiplier)), "add_mslot3");
    m.add_item("Add 25 manual slots for "   + convert_to_currency(calc_slot_cost(25,   manualSlotBaseCost, manualSlotMultiplier)), "add_mslot4");
    m.add_item("Add 50 manual slots for "   + convert_to_currency(calc_slot_cost(50,   manualSlotBaseCost, manualSlotMultiplier)), "add_mslot5");
    m.add_item("Add 100 manual slots for "  + convert_to_currency(calc_slot_cost(100,  manualSlotBaseCost, manualSlotMultiplier)), "add_mslot6");
    m.add_item("Add 250 manual slots for "  + convert_to_currency(calc_slot_cost(250,  manualSlotBaseCost, manualSlotMultiplier)), "add_mslot7");
    m.add_item("Add 500 manual slots for "  + convert_to_currency(calc_slot_cost(500,  manualSlotBaseCost, manualSlotMultiplier)), "add_mslot8");
    m.add_item("Add 1000 manual slots for " + convert_to_currency(calc_slot_cost(1000, manualSlotBaseCost, manualSlotMultiplier)), "add_mslot9");
    m.add_item("Add 2500 manual slots for " + convert_to_currency(calc_slot_cost(2500, manualSlotBaseCost, manualSlotMultiplier)), "add_mslot10");
    m.add_item("Add 5000 manual slots for " + convert_to_currency(calc_slot_cost(5000, manualSlotBaseCost, manualSlotMultiplier)), "add_mslot11");
    m.add_item("Add 10000 manual slots for "+ convert_to_currency(calc_slot_cost(10000,manualSlotBaseCost, manualSlotMultiplier)), "add_mslot12");
    m.add_item("Back", "back");
    m.intro_text = "Manual slots menu. You have " + string(manualSlots) + " manual " + (manualSlots == 1 ? "slot" : "slots") + ".";
    int start_pos = 0;
    if (last_menu_id != "")
    {
        int found = m.find_item_by_id(last_menu_id);
        if (found != -1)
            start_pos = found;
    }
    int mres = m.run(start_pos, true);
    string sel = m.get_item_id(mres);
    if (mres != -1)
        last_menu_id = sel;
    if (mres == -1 || sel == "back")
    {
        last_menu_id = "";
        manage_baking_slots();
        return;
    }
    int count = 0;
    if (sel == "add_mslot1")  count = 1;
    if (sel == "add_mslot2")  count = 5;
    if (sel == "add_mslot3")  count = 10;
    if (sel == "add_mslot4")  count = 25;
    if (sel == "add_mslot5")  count = 50;
    if (sel == "add_mslot6")  count = 100;
    if (sel == "add_mslot7")  count = 250;
    if (sel == "add_mslot8")  count = 500;
    if (sel == "add_mslot9")  count = 1000;
    if (sel == "add_mslot10") count = 2500;
    if (sel == "add_mslot11") count = 5000;
    if (sel == "add_mslot12") count = 10000;
    if (count > 0)
    {
        double cost = calc_slot_cost(count, manualSlotBaseCost, manualSlotMultiplier);
        if (coins >= cost)
        {
            coins -= cost;
            stat_coins_spent += cost;
            manualSlots += count;
            stat_manual_slots_purchased += count;
            for (int i = 0; i < count; i++)
                manualSlotBaseCost *= manualSlotMultiplier;
            pool.destroy_sound(alertslot);
            alertslot = pool.play_stationary("sounds/misc/prodslot.ogg", false);
            speak("Added " + string(count) + " manual " + (count == 1 ? "slot" : "slots") + ". You now have " + string(manualSlots) + " manual " + (manualSlots == 1 ? "slot" : "slots") + ".");
            add_manual_slots();
        }
        else
        {
            alertslot = pool.play_stationary("sounds/dlg/error.ogg", false);
            dlg("Error! You can't afford " + string(count) + " manual " + (count == 1 ? "slot" : "slots") + "!");
            pool.destroy_sound(alertslot);
            add_manual_slots();
        }
    }
}
void auto_slots_menu()
{
    setupmenu(false);
    m.add_item("Add a slot", "add");
    m.add_item("Automate a slot", "automate");
    m.add_item("Back", "back");
    int produced = baking_slots.length();
    int automated = autobakeSlots;
    int nonauto = produced - automated;
    m.intro_text = "Auto slots menu. You have " + string(produced) + " produced " + (produced == 1 ? "slot" : "slots") + ", " + string(automated) + " automated " + (automated == 1 ? "slot" : "slots") + ", and " + string(nonauto) + " unautomated " + (nonauto == 1 ? "slot" : "slots") + ".";
    int mres = m.run();
    string selected = m.get_item_id(mres);
    if (mres == -1 || selected == "back")
    {
        manage_baking_slots();
        return;
    }
    if (selected == "add")
    {
        last_menu_id = "";
        add_auto_slots();
        return;
    }
    if (selected == "automate")
    {
        automate_baking_slots();
        return;
    }
}
void manage_baking_slots()
{
    setupmenu(false);
    m.add_item("Auto slots", "auto");
    m.add_item("Manual slots", "manual");
    m.add_item("Back", "back");
    int produced = baking_slots.length();
    int automated = autobakeSlots;
    int nonauto = produced - automated;
    m.intro_text = "Baking slots manager menu. What would you like to do?";
    int mres = m.run();
    string selected = m.get_item_id(mres);
    if (mres == -1 || selected == "back")
    {
        clickergame();
        return;
    }
    if (selected == "manual")
    {
        if (rank < slotManagerUnlockRank)
        {
            dlgmessage_return("Manual slots are locked. Please reach rank " + int(slotManagerUnlockRank) + " to use this feature.");
            manage_baking_slots();
            return;
        }
        last_menu_id = "";
        add_manual_slots();
        return;
    }
    if (selected == "auto")
    {
        if (rank < slotManagerUnlockRank)
        {
            dlgmessage_return("Auto slots are locked. Please reach rank " + int(slotManagerUnlockRank) + " to use this feature.");
            manage_baking_slots();
            return;
        }
        auto_slots_menu();
        return;
    }
}
void automate_baking_slots()
{
        int nonAutoCount = 0;
        for (uint i = 0; i < autobakeSlotEnabled.length(); i++)
        {
            if (!autobakeSlotEnabled[i]) nonAutoCount++;
        }
        if (nonAutoCount == 0)
        {
            alertslot = pool.play_stationary("sounds/dlg/error.ogg", false);
            dlg("Error! There are no slots available to automate.");
            pool.destroy_sound(alertslot);
            auto_slots_menu();
            return;
        }
        setupmenu(false);
        for (uint i = 0; i < autobakeSlotEnabled.length(); i++)
        {
            if (!autobakeSlotEnabled[i])
            {
                m.add_item("Slot " + string(i + 1) + " (unautomated)", "slot" + string(i));
            }
        }
        if (nonAutoCount > 1)
        {
            double totalCost = calc_automation_cost(nonAutoCount, automationBaseCost, automationMultiplier);
            m.add_item("Automate ALL slots for " + convert_to_currency(totalCost), "automate_all");
        }
        m.add_item("Back", "back");
        m.intro_text = "Slot automation menu.";
        int slotres = m.run();
        if (slotres == -1 || m.get_item_id(slotres) == "back")
        {
            auto_slots_menu();
            return;
        }
        string s = m.get_item_id(slotres);
        if (s == "automate_all")
        {
            double totalCost = calc_automation_cost(nonAutoCount, automationBaseCost, automationMultiplier);
            if (coins >= totalCost)
            {
                coins -= totalCost;
                stat_coins_spent += totalCost;
                for (uint i = 0; i < autobakeSlotEnabled.length(); i++)
                {
                    if (!autobakeSlotEnabled[i])
                    {
                        autobakeSlotEnabled[i] = true;
                        autobakeSlots++;
                        automationBaseCost *= automationMultiplier;
                    }
                }
                stat_auto_slots_enabled += nonAutoCount;
                pool.destroy_sound(alertslot);
                alertslot = pool.play_stationary("sounds/misc/autslot.ogg", false);
                speak("Successfully automated " + string(nonAutoCount) + " slot" + (nonAutoCount == 1 ? "" : "s") + ".");
            }
            else
            {
                alertslot = pool.play_stationary("sounds/dlg/error.ogg", false);
                dlg("Error! You can't afford to automate all slots!");
                pool.destroy_sound(alertslot);
            }
            auto_slots_menu();
            return;
        }
        if (s.substr(0, 4) == "slot")
        {
            int index = string_to_int(s.substr(4));
            if (index >= 0 && index < autobakeSlotEnabled.length() && !autobakeSlotEnabled[index])
            {
                setupmenu(false);
                double singleCost = calc_automation_cost(1, automationBaseCost, automationMultiplier);
                m.add_item("Automate this slot for " + convert_to_currency(singleCost), "automate");
                m.add_item("Preview slot sound", "preview");
                m.add_item("Back", "back");
                m.intro_text = "Slot " + string(index + 1) + " menu.";
                int subres = m.run();
                if (subres == -1 || m.get_item_id(subres) == "back")
                {
                    auto_slots_menu();
                    return;
                }
                if (m.get_item_id(subres) == "preview")
                {
                    pool.play_stationary("sounds/misc/autobake.ogg", false);
                    auto_slots_menu();
                    return;
                }
                if (m.get_item_id(subres) == "automate")
                {
                    if (coins >= singleCost)
                    {
                        coins -= singleCost;
                        stat_coins_spent += singleCost;
                        autobakeSlotEnabled[index] = true;
                        autobakeSlots++;
                        stat_auto_slots_enabled++;
                        automationBaseCost *= automationMultiplier;
                        pool.destroy_sound(alertslot);
                        alertslot = pool.play_stationary("sounds/misc/autslot.ogg", false);
                        speak("Slot " + string(index + 1) + " is now automated.");
                    }
                    else
                    {
                        alertslot = pool.play_stationary("sounds/dlg/error.ogg", false);
                        dlg("Error! You can't afford to automate this slot!");
                        pool.destroy_sound(alertslot);
                    }
                    auto_slots_menu();
                    return;
                }
            }
        }
}

void questsmenu()
{
    form.reset();
    form.create_window("Quests", false);
    int filterList = form.create_list("Quest &Category", 3, false, false);
    form.add_list_item(filterList, "All", "all", -1, true);
    form.add_list_item(filterList, "Required", "required", -1, true);
    form.add_list_item(filterList, "Random", "random", -1, true);
    form.set_list_position(filterList, 0);
    int questList = form.create_list("&Quests", 0, false, false);
    quest_item@[] questOrder;
    int lastFilter = 0;
    for (uint i = 0; i < activeQuests.length(); i++)
    {
        if (lastFilter == 2 && activeQuests[i].required) continue;
        if (lastFilter == 1 && !activeQuests[i].required) continue;
        if (!activeQuests[i].required) continue;
        bool questDone = get_stat_value(activeQuests[i].stat) >= activeQuests[i].threshold;
        string questLabel = activeQuests[i].name + (questDone ? ". Complete" : "");
        form.add_list_item(questList, questLabel, activeQuests[i].id, -1, true);
        questOrder.insert_last(activeQuests[i]);
    }
    for (uint i = 0; i < activeQuests.length(); i++)
    {
        if (lastFilter == 1 && !activeQuests[i].required) continue;
        if (lastFilter == 2 && activeQuests[i].required) continue;
        if (activeQuests[i].required) continue;
        bool questDone = get_stat_value(activeQuests[i].stat) >= activeQuests[i].threshold;
        string questLabel = activeQuests[i].name + (questDone ? ". Complete" : "");
        form.add_list_item(questList, questLabel, activeQuests[i].id, -1, true);
        questOrder.insert_last(activeQuests[i]);
    }
    int detailBox = form.create_input_box("&Quest details", "", read_only:true, multiline:true);
    double rerollCost = floor(questsConfig.reroll_base_cost * pow(questsConfig.reroll_multiplier, questRerollCount));
    int rerollBtn = -1;
    string rerollHistText = "";
    if (rerollHistory.length() == 0)
        rerollHistText = "No rerolls recorded yet.";
    else
    {
        for (uint i = 0; i < rerollHistory.length(); i++)
            rerollHistText += "Reroll " + string(i + 1) + ": " + rerollHistory[i].old_name + " replaced by " + rerollHistory[i].new_name + ". Cost: " + (rerollHistory[i].target == "coins" ? convert_to_currency(rerollHistory[i].cost) : format_number(rerollHistory[i].cost) + " " + rerollHistory[i].target) + ".\r\n";
    }
    int rerollHistBox = -1;
    bool prestigeAvailable = rank >= prestigeConfig.min_rank;
    bool lastRewardEarned = quests_reward_earned();
    string prestigeLabel = !prestigeAvailable ? "&Prestige, unlocked at rank " + string(prestigeConfig.min_rank) : (lastRewardEarned ? "&Prestige, reward available" : "&Prestige, no reward available");
    int prestigeBtn = form.create_button(prestigeLabel);
    int prestigeStoreBtn = -1;
    if (prestigeHistory.length() > 0)
        prestigeStoreBtn = form.create_button("Prestige &store");
    string prestigeHistText = "";
    if (prestigeHistory.length() == 0)
        prestigeHistText = "No prestige runs recorded yet.";
    else
    {
        for (uint i = 0; i < prestigeHistory.length(); i++)
            prestigeHistText += "Prestige level " + string(prestigeHistory[i].level) + ". Reached rank " + string(prestigeHistory[i].rank_reached) + ". Reward: " + prestigeHistory[i].reward + ".\r\n";
    }
    int historyBox = form.create_input_box("Prestige &History", prestigeHistText, read_only:true, multiline:true);
    int closeBtn = form.create_button("&Close", false, true);
    form.focus(filterList);
    form.set_list_position(questList, 0);
    int lastPos = -1;
    bool lastRequired = true;
    bool lastComplete = false;
    while (true)
    {
        wait(5);
        form.monitor();
        int curFilter = form.get_list_position(filterList);
        int curPos = form.get_list_position(questList);
        bool rewardEarned = quests_reward_earned();
        bool nowAvailable = rank >= prestigeConfig.min_rank;
        string newPrestigeLabel = !nowAvailable ? "&Prestige, unlocked at rank " + string(prestigeConfig.min_rank) : (rewardEarned ? "&Prestige, reward available" : "&Prestige, no reward available");
        if (curFilter != lastFilter)
        {
            lastFilter = curFilter;
            form.clear_list(questList);
            questOrder.resize(0);
            for (uint i = 0; i < activeQuests.length(); i++)
            {
                if (lastFilter == 2 && activeQuests[i].required) continue;
                if (lastFilter == 1 && !activeQuests[i].required) continue;
                if (!activeQuests[i].required) continue;
                bool questDone = get_stat_value(activeQuests[i].stat) >= activeQuests[i].threshold;
                string questLabel = activeQuests[i].name + (questDone ? ". Complete" : "");
                form.add_list_item(questList, questLabel, activeQuests[i].id, -1, true);
                questOrder.insert_last(activeQuests[i]);
            }
            for (uint i = 0; i < activeQuests.length(); i++)
            {
                if (lastFilter == 1 && !activeQuests[i].required) continue;
                if (lastFilter == 2 && activeQuests[i].required) continue;
                if (activeQuests[i].required) continue;
                bool questDone = get_stat_value(activeQuests[i].stat) >= activeQuests[i].threshold;
                string questLabel = activeQuests[i].name + (questDone ? ". Complete" : "");
                form.add_list_item(questList, questLabel, activeQuests[i].id, -1, true);
                questOrder.insert_last(activeQuests[i]);
            }
            form.set_list_position(questList, 0);
            form.set_text(detailBox, questOrder.length() > 0 ? get_quest_detail(questOrder[0]) : "");
            bool showReroll = false;
            bool firstComplete = questOrder.length() > 0 && get_stat_value(questOrder[0].stat) >= questOrder[0].threshold;
            if (lastFilter == 2) showReroll = true;
            else if (lastFilter == 0 && questOrder.length() > 0 && !questOrder[0].required)
            {
                if (questsConfig.reroll_warning == 5 && firstComplete) showReroll = false;
                else showReroll = true;
            }
            lastComplete = firstComplete;
            if (rerollBtn != -1) form.delete_control(rerollBtn);
            if (rerollHistBox != -1) form.delete_control(rerollHistBox);
            form.delete_control(prestigeBtn);
            form.delete_control(historyBox);
            form.delete_control(closeBtn);
            if (showReroll)
            {
                rerollBtn = form.create_button("&Reroll quest for " + (questsConfig.reroll_target == "coins" ? convert_to_currency(rerollCost) : format_number(rerollCost) + " " + questsConfig.reroll_target));
                rerollHistBox = form.create_input_box("&Reroll History", rerollHistText, read_only:true, multiline:true);
            }
            else
            {
                rerollBtn = -1;
                rerollHistBox = -1;
            }
            prestigeBtn = form.create_button(prestigeLabel);
            historyBox = form.create_input_box("Prestige &History", prestigeHistText, read_only:true, multiline:true);
            closeBtn = form.create_button("&Close", false, true);
            lastRequired = (questOrder.length() > 0) ? questOrder[0].required : true;
            lastComplete = firstComplete;
            lastPos = 0;
            form.focus_silently(filterList);
            continue;
        }
        if (newPrestigeLabel != prestigeLabel)
        {
            if (rerollHistBox != -1) form.delete_control(rerollHistBox);
            form.delete_control(prestigeBtn);
            form.delete_control(historyBox);
            form.delete_control(closeBtn);
            prestigeLabel = newPrestigeLabel;
            if (rerollHistBox != -1) rerollHistBox = form.create_input_box("&Reroll History", rerollHistText, read_only:true, multiline:true);
            prestigeBtn = form.create_button(prestigeLabel);
            historyBox = form.create_input_box("Prestige &History", prestigeHistText, read_only:true, multiline:true);
            closeBtn = form.create_button("&Close", false, true);
            form.focus_silently(questList);
        }
        if (curPos != lastPos && curPos >= 0 && curPos < int(questOrder.length()))
        {
            form.set_text(detailBox, get_quest_detail(questOrder[curPos]));
            bool isRequired = questOrder[curPos].required;
            bool isComplete = get_stat_value(questOrder[curPos].stat) >= questOrder[curPos].threshold;
            bool shouldShow = !isRequired && !(questsConfig.reroll_warning == 5 && isComplete);
            bool shouldShowPrev = !lastRequired && !(questsConfig.reroll_warning == 5 && lastComplete);
            if (lastFilter == 0 && shouldShow != shouldShowPrev)
            {
                if (rerollBtn != -1) form.delete_control(rerollBtn);
                if (rerollHistBox != -1) form.delete_control(rerollHistBox);
                form.delete_control(prestigeBtn);
                form.delete_control(historyBox);
                form.delete_control(closeBtn);
                if (shouldShow)
                {
                    rerollBtn = form.create_button("&Reroll quest for " + (questsConfig.reroll_target == "coins" ? convert_to_currency(rerollCost) : format_number(rerollCost) + " " + questsConfig.reroll_target));
                    rerollHistBox = form.create_input_box("&Reroll History", rerollHistText, read_only:true, multiline:true);
                }
                else
                {
                    rerollBtn = -1;
                    rerollHistBox = -1;
                }
                prestigeBtn = form.create_button(prestigeLabel);
                historyBox = form.create_input_box("Prestige &History", prestigeHistText, read_only:true, multiline:true);
                closeBtn = form.create_button("&Close", false, true);
                lastRequired = isRequired;
                lastComplete = isComplete;
                form.focus_silently(questList);
            }
            lastPos = curPos;
        }
        if (form.is_pressed(prestigeBtn))
        {
            if (rank < prestigeConfig.min_rank)
            {
                dlgmessage_return("You must reach rank " + string(prestigeConfig.min_rank) + " to use this feature.");
                form.reset();
                questsmenu();
                return;
            }
            else
            {
                start_prestige();
                form.reset();
                questsmenu();
                return;
            }
        }
        if (prestigeStoreBtn != -1 && form.is_pressed(prestigeStoreBtn))
        {
            form.reset();
            prestige_store_menu();
            return;
        }
        if (rerollBtn != -1 && form.is_pressed(rerollBtn))
        {
            int rerollPos = form.get_list_position(questList);
            if (rerollPos < 0 || rerollPos >= int(questOrder.length()))
            {
                form.reset();
                questsmenu();
                return;
            }
            bool rerollQuestComplete = get_stat_value(questOrder[rerollPos].stat) >= questOrder[rerollPos].threshold;
            int rwarn = questsConfig.reroll_warning;
            bool doConfirm = false;
            bool doBlock = false;
            if (rwarn == 2 && !rerollQuestComplete) doConfirm = true;
            else if (rwarn == 3 && rerollQuestComplete) doConfirm = true;
            else if (rwarn == 4) doConfirm = true;
            else if (rwarn == 5 && rerollQuestComplete) doBlock = true;
            if (doBlock)
            {
                form.reset();
                questsmenu();
                return;
            }
            if (doConfirm)
            {
                setupmenu(false);
                m.add_item("Yes", "yes");
                m.add_item("No", "no");
                if (rerollQuestComplete)
                    m.intro_text = "Are you sure you want to reroll this quest? This quest is already complete. Rerolling it will remove its completed status, which may affect your prestige reward. This action cannot be undone.";
                else
                    m.intro_text = "Are you sure you want to reroll this quest? This action cannot be undone.";
                int wres = m.run();
                if (wres == -1 || m.get_item_id(wres) == "no")
                {
                    form.reset();
                    questsmenu();
                    return;
                }
            }
            double rerollConfirmCost = floor(questsConfig.reroll_base_cost * pow(questsConfig.reroll_multiplier, questRerollCount));
            double rerollStatVal = 0;
            if (questsConfig.reroll_target == "coins")           rerollStatVal = coins;
            else if (questsConfig.reroll_target == "cookies")    rerollStatVal = cookies;
            else if (questsConfig.reroll_target == "autocookie")  rerollStatVal = autocookie;
            else if (questsConfig.reroll_target == "manulcookie") rerollStatVal = manulcookie;
            else if (questsConfig.reroll_target == "cookiespeed") rerollStatVal = cookiespeed;
            if (rerollStatVal < rerollConfirmCost)
            {
                double rerollShortfall = rerollConfirmCost - rerollStatVal;
                string rerollUnit = questsConfig.reroll_target;
                if (rerollShortfall == 1)
                {
                    if (rerollUnit == "coins")           rerollUnit = "coin";
                    else if (rerollUnit == "cookies")    rerollUnit = "cookie";
                    else if (rerollUnit == "autocookie")  rerollUnit = "auto cookie";
                    else if (rerollUnit == "manulcookie") rerollUnit = "manual cookie";
                    else if (rerollUnit == "cookiespeed") rerollUnit = "cookie speed";
                }
                else
                {
                    if (rerollUnit == "autocookie")       rerollUnit = "auto cookies";
                    else if (rerollUnit == "manulcookie") rerollUnit = "manual cookies";
                    else if (rerollUnit == "cookiespeed") rerollUnit = "cookie speeds";
                }
                string rerollCostStr;
                if (questsConfig.reroll_target == "coins")
                {
                    string cs = convert_to_currency(rerollShortfall);
                    int spacePos = cs.find(" ");
                    if (spacePos != -1)
                        rerollCostStr = cs.substr(0, spacePos) + " more " + cs.substr(spacePos + 1);
                    else
                        rerollCostStr = cs + " more";
                }
                else
                    rerollCostStr = format_number(rerollShortfall) + " more " + rerollUnit;
                dlgmessage_return("You cannot afford to reroll this quest. You need " + rerollCostStr + " to do this.");
                form.reset();
                questsmenu();
                return;
            }
            setupmenu(false);
            m.add_item("Yes", "yes");
            m.add_item("No", "no");
            m.intro_text = "Are you sure you want to reroll this quest? This action cannot be undone.";
            int mres = m.run();
            if (mres == -1 || m.get_item_id(mres) == "no")
            {
                form.reset();
                questsmenu();
                return;
            }
            string rerollId = questOrder[rerollPos].id;
            int actualRerollPos = -1;
            for (uint ri = 0; ri < activeQuests.length(); ri++)
            {
                if (activeQuests[ri].id == rerollId) { actualRerollPos = ri; break; }
            }
            if (actualRerollPos != -1) reroll_quest(actualRerollPos);
            form.reset();
            questsmenu();
            return;
        }
        if (form.is_pressed(closeBtn) || key_pressed(KEY_ESCAPE))
        {
            form.reset();
            clickergame();
            return;
        }
    }
}

void start_prestige()
{
    setupmenu(false);
    m.add_item("Yes", "yes");
    m.add_item("No", "no");
    string confirmText = "Are you sure you want to prestige? Your cookies, money, rank, upgrades, and baking slots will be reset. Your achievements, minigame stats, and prestige bonus will be kept.";
    bool willGetReward = quests_reward_earned();
    if (!willGetReward)
        confirmText += " Warning: you have not met the quest requirement, so you will not receive any reward for this prestige.";
    else
        confirmText += " You have met the quest requirement and will receive your reward.";
    m.intro_text = confirmText;
    int mres = m.run();
    if (mres == -1 || m.get_item_id(mres) == "no")
    {
        form.reset();
        clickergame();
        return;
    }
    ambpool.pause_sound(ambslot);
    muspool.pause_sound(mustrackslot);
    writedata();
    resetgame(true);
    writedata();
    ambpool.resume_sound(ambslot);
    muspool.resume_sound(mustrackslot);
    form.reset();
    clickergame();
}

void preffsmenu()
{
form.reset();
    form.create_window("preferences", false);
    int audsets = form.create_button("&audio settings");
int gamsets = form.create_button("&game settings");
int usersets = form .create_button("&user settings");
form.focus(audsets);
    while (true)
    {
        form.monitor();
        wait(5);
        if (form.is_pressed(gamsets))
        {
gamsetsmenu();
}
        if (form.is_pressed(audsets))
        {
soundsetsmenu();
}
        if (form.is_pressed(usersets))
        {
usersetsmenu();
}
        if (key_pressed(KEY_ESCAPE))
        {
if(ingame==true)
{
form.reset();
clickergame();
}
else if(ingame==false)
{
mainmenu();
}
    }
}
}
void gamsetsmenu()
{
    form.reset();
    form.create_window("Game Settings", false);
int logoSFX = form.create_checkbox("Enable playing the logo sound upon launching the game.", logosfx);
int introSFX = form.create_checkbox("Enable playing the intro sound upon starting the game.", introsfx);
int exitSFX = form.create_checkbox("Enable playing the exit sound upon exiting the game.", exitsfx);
int bakeSFX = form.create_checkbox("Enable auto bake sound effects when baking cookies.", bakesfx);
int coinSFX = form.create_checkbox("Enable currency sound effects when earning money.", coinsfx);
int eventSFX = form.create_checkbox("Enable event sound effects when events trigger.", eventsfx);
int achSFX = form.create_checkbox("Enable achievement sound effects when unlocking achievements.", achsfx);
int rankSFX = form.create_checkbox("Enable rank sound effects when leveling up.", ranksfx);
int saveSFX = form.create_checkbox("Enable save sound effects when reloading and saving the game.", savesfx);
int playvents = form.create_checkbox("Enable player events during auto baking.", playervents);
int playvents2 = form.create_checkbox("Enable player events during manual baking.", playervents2);
int ordsyms = form.create_checkbox("Enable alphabetical symbol listing for the slot machine mini game.", orderedSyms);
int reelspin = form.create_checkbox("Enable automatic stopping of reels for the slot machine mini game.", slotmode);
int jackautodraw = form.create_checkbox("Enable automatic card drawing for the blackjack mini game.", jackmode);
int lotteryautoscratch = form.create_checkbox("Enable automatic scratch revealing for the cookie lottery mini game.", lotterymode);
int flipautoflip = form.create_checkbox("Enable automatic flipping for the cookie flipper mini game.", flipmode);
int diceautoroll = form.create_checkbox("Enable automatic rolling for the dice roller mini game.", dicemode);
int bakeSplitToggle = form.create_checkbox("Enable evenly distributing cookie production across automated slots.", slotDistribution);
int manualBakeSplitToggle = form.create_checkbox("Enable evenly distributing cookie production across manual slots.", manualSlotDistribution);
int showLockedToggle = form.create_checkbox("Enable showing locked items and menus in the shop list.", show_locked_shops);
int automationMultiplierSlider = form.create_slider("Automation slot Cost Multiplier.", round((automationMultiplier - 1.0) * 100, 0), 1, 100, "X", 1);
int slotMultiplierSlider = form.create_slider("Auto slot production Cost Multiplier.", round((slotMultiplier - 1.0) * 100, 0), 1, 100, "X", 1);
int manualSlotMultiplierSlider = form.create_slider("Manual slot production Cost Multiplier.", round((manualSlotMultiplier - 1.0) * 100, 0), 1, 100, "X", 1);
int cookieRankModifierSlider = form.create_slider("Cookie Rank Modifier.", cookiemod, 1, 100, "x", 1);
int difficultyRankModifierSlider = form.create_slider("Difficulty rank Modifier.", difmod, 1, 100, "x", 1);
int autoChanceSlider = form.create_slider("Auto-Baking Event chance.", 100 - evchanse, 0, 100, "percent", 1);
int manualChanceSlider = form.create_slider("Manual-Baking Event chance.", 100 - evchanse2, 0, 100, "percent", 1);
int sellPriceSlider = form.create_slider("Cookie sell price.", cookieSellPrice, 1, 100, "cents", 1);
int savesets = form.create_button("&save settings", true);
int cansets = form.create_button("&cancel");
form.focus(logoSFX);
    while (true)
    {
        wait(5);
        form.monitor();
automationMultiplier = 1.0 + (form.get_slider(automationMultiplierSlider) * 0.01);
slotMultiplier = 1.0 + (form.get_slider(slotMultiplierSlider) * 0.01);
manualSlotMultiplier = 1.0 + (form.get_slider(manualSlotMultiplierSlider) * 0.01);
cookiemod = form.get_slider(cookieRankModifierSlider);
difmod = form.get_slider(difficultyRankModifierSlider);
evchanse = 100 - form.get_slider(autoChanceSlider);
evchanse2 = 100 - form.get_slider(manualChanceSlider);
cookieSellPrice = form.get_slider(sellPriceSlider);
introsfx = form.is_checked(introSFX);
logosfx = form.is_checked(logoSFX);
exitsfx = form.is_checked(exitSFX);
bakesfx = form.is_checked(bakeSFX);
        coinsfx = form.is_checked(coinSFX);
eventsfx = form.is_checked(eventSFX);
        ranksfx = form.is_checked(rankSFX);
achsfx = form.is_checked(achSFX);
savesfx = form.is_checked(saveSFX);
slotDistribution = form.is_checked(bakeSplitToggle);
manualSlotDistribution = form.is_checked(manualBakeSplitToggle);
show_locked_shops = form.is_checked(showLockedToggle);
        playervents = form.is_checked(playvents);
        playervents2 = form.is_checked(playvents2);
orderedSyms = form.is_checked(ordsyms);
slotmode = form.is_checked(reelspin);
jackmode = form.is_checked(jackautodraw);
lotterymode = form.is_checked(lotteryautoscratch);
flipmode = form.is_checked(flipautoflip);
dicemode = form.is_checked(diceautoroll);
        if (form.is_pressed(savesets))
        {
writepreffs();
            dlgmessage_return("Settings saved.");
writedata();
readdata();
            preffsmenu();
        }
if (key_pressed(KEY_ESCAPE))
        {
preffsmenu();
}
            if (form.is_pressed(cansets))
        {
preffsmenu();
}
}
}
void soundsetsmenu()
{
form.reset();
    form.create_window("audio settings", false);
int amblist, musslist;
if(ingame==true) amblist = form.create_list("ambience sound:", 4);
if(ingame==true) musslist = form.create_list("music track:", 20);
    string[] ambOptions;
    for (uint i = 1; i <= 4; i++)
    {
        string ambName = "Room " + i;
        string ambID = "room" + i;
        ambOptions.insert_last(ambID);
        form.add_list_item(amblist, ambName, ambID);
    }
    string[] musOptions;
    for (uint i = 1; i <= 20; i++)
    {
        string musName = "Music " + i;
        string musID = "music" + i;
        musOptions.insert_last(musID);
        form.add_list_item(musslist, musName, musID);
    }
if(ingame==true) form.set_list_position(amblist, ambienceIndex);
if(ingame==true) form.set_list_position(musslist, musicIndex);
int gameAmbienceVolumeSlider = form.create_slider("game ambience volume, ", (ambvolume + 50) * 2, 0, 100, "percent", 1);
int gameMusicVolumeSlider = form.create_slider("game music volume, ", (musvolume + 50) * 2, 0, 100, "percent", 1);
int storeAmbienceVolumeSlider = form.create_slider("store ambience volume, ", (storambvolume + 50) * 2, 0, 100, "percent", 1);
int storeMusicVolumeSlider = form.create_slider("store music volume, ", (stormusvolume + 50) * 2, 0, 100, "percent", 1);
int savesets = form.create_button("&save settings", true);
int cansets = form.create_button("&cancel");
form.focus(amblist);
    while (true)
    {
        wait(5);
        form.monitor();
ambvolume = (form.get_slider(gameAmbienceVolumeSlider) / 2) - 50;
musvolume = (form.get_slider(gameMusicVolumeSlider) / 2) - 50;
storambvolume = (form.get_slider(storeAmbienceVolumeSlider) / 2) - 50;
stormusvolume = (form.get_slider(storeMusicVolumeSlider) / 2) - 50;
        ambpool.update_sound_start_values(ambslot, 0, ambvolume, ambpitch);
        muspool.update_sound_start_values(mustrackslot, 0, musvolume, muspitch);
storambpool.update_sound_start_values(storambslot, 0, storambvolume, storambpitch);
stormuspool.update_sound_start_values(stortrackslot, 0, stormusvolume, stormuspitch);
if(ingame==true) ambienceIndex = form.get_list_position(amblist);
        if (ambienceIndex != -1 && ambOptions[ambienceIndex] != ambtype)
        {
            ambtype = ambOptions[ambienceIndex];
            ambpool.destroy_sound(ambslot);
            ambslot = ambpool.play_stationary_extended("sounds/ambience/"+ambtype + ".ogg", true, 0, 0, ambvolume, ambpitch, false);
        }
if(ingame==true) musicIndex = form.get_list_position(musslist);
        if (musicIndex != -1 && musOptions[musicIndex] != mustype)
        {
            mustype = musOptions[musicIndex];
            muspool.destroy_sound(mustrackslot);
            mustrackslot = muspool.play_stationary_extended("sounds/ambience/"+mustype + ".ogg", true, 0, 0, musvolume, muspitch, false);
        }
        if (form.is_pressed(savesets))
        {
writepreffs2();
dlgmessage_return("Settings saved.");
preffsmenu();
}
        if (key_pressed(KEY_ESCAPE))
        {
preffsmenu();
}
            if (form.is_pressed(cansets))
        {
preffsmenu();
}
    }
}
void usersetsmenu()
{
    string gendertext;
    if (playergender == 0)
{
        gendertext = "Male";
    }
else if (playergender == 1)
{
        gendertext = "Female";
    }
else if (playergender == 2)
{
        gendertext = "Non-binary";
    }
else
{
        gendertext = "Unknown";
    }
    form.reset();
    form.create_window("User Settings", false);
    int charname = form.create_button("Change the character's &first name. Currently set to "+playername+".");
    int charname2 = form.create_button("Change the character's &last name. Currently set to "+playername2+".");
    int chargender = form.create_list("Change the character's &gender. Currently set to " + gendertext + ".", 3);
    form.add_list_item(chargender, "Male");
    form.add_list_item(chargender, "Female");
    form.add_list_item(chargender, "Non-binary");
    if (playergender >= 0 && playergender <= 2)
{
        form.set_list_position(chargender, playergender);
    }
int savesets = form.create_button("&save settings", true);
int cansets = form.create_button("&cancel");
form.focus(charname);
    while (true)
    {
        form.monitor();
        wait(5);
playergender = form.get_list_position(chargender);
        if (form.is_pressed(charname))
        {
vd.set_disallowed_chars(" !@#$%^&*()[]{};:'\"\\|,.<>?/+-=`~_", false, "This character is not allowed.");
string fn=vd.input_box("","Enter the first name of this character.");
if(fn.is_empty())
{
alertslot=pool.play_stationary("sounds/dlg/error.ogg",false);
dlg("Error! Your character's first name is invalid!");
pool.destroy_sound(alertslot);
            form.reset();
            usersetsmenu();
}
else
{
playername=fn;
            dlgmessage_return("Success! Your character's first name has now been changed to "+playername+".");
            form.reset();
            usersetsmenu();
}
}
        if (form.is_pressed(charname2))
        {
vd.set_disallowed_chars(" !@#$%^&*()[]{};:'\"\\|,.<>?/+-=`~_", false, "This character is not allowed.");
string fn2=vd.input_box("","Enter the last name of this character.");
if(fn2.is_empty())
{
pool.play_stationary("sounds/dlg/error.ogg",false);
dlg("Error! Your character's last name is invalid!");
pool.destroy_sound(alertslot);
            form.reset();
            usersetsmenu();
}
else
{
playername2=fn2;
            dlgmessage_return("Success! Your character's last name has now been changed to "+playername2+".");
            form.reset();
            usersetsmenu();
}
}
        if (form.is_pressed(savesets))
        {
            writepreffs3();
            dlgmessage_return("Settings saved.");
preffsmenu();
        }
        if (key_pressed(KEY_ESCAPE))
        {
preffsmenu();
}
            if (form.is_pressed(cansets))
        {
preffsmenu();
}
    }
}
