    m.add_item("Add 50 manual slots for "   + format_number(calc_slot_cost(50,   manualSlotBaseCost, manualSlotMultiplier)) + " coins", "add_mslot5");
    m.add_item("Add 100 manual slots for "  + format_number(calc_slot_cost(100,  manualSlotBaseCost, manualSlotMultiplier)) + " coins", "add_mslot6");
    m.add_item("Add 250 manual slots for "  + format_number(calc_slot_cost(250,  manualSlotBaseCost, manualSlotMultiplier)) + " coins", "add_mslot7");
    m.add_item("Add 500 manual slots for "  + format_number(calc_slot_cost(500,  manualSlotBaseCost, manualSlotMultiplier)) + " coins", "add_mslot8");
    m.add_item("Add 1000 manual slots for " + format_number(calc_slot_cost(1000, manualSlotBaseCost, manualSlotMultiplier)) + " coins", "add_mslot9");
    m.add_item("Add 2500 manual slots for " + format_number(calc_slot_cost(2500, manualSlotBaseCost, manualSlotMultiplier)) + " coins", "add_mslot10");
    m.add_item("Add 5000 manual slots for " + format_number(calc_slot_cost(5000, manualSlotBaseCost, manualSlotMultiplier)) + " coins", "add_mslot11");
    m.add_item("Add 10000 manual slots for "+ format_number(calc_slot_cost(10000,manualSlotBaseCost, manualSlotMultiplier)) + " coins", "add_mslot12");
    m.add_item("Back", "back");
    m.intro_text = "Manual slots menu. You have " + string(manualSlots) + " manual " + (manualSlots == 1 ? "slot" : "slots") + ".";
    int start_pos = 0;
    if (last_menu_id != "")
    {
        int found = m.find_item_by_id(last_menu_id);
        if (found != -1)
            start_pos = found;
    }
    int mres = m.run(start_pos, true);
    string sel = m.get_item_id(mres);
    if (mres != -1)
        last_menu_id = sel;
    if (mres == -1 || sel == "back")
    {
        last_menu_id = "";
        manage_baking_slots();
        return;
    }
    int count = 0;
    if (sel == "add_mslot1")  count = 1;
    if (sel == "add_mslot2")  count = 5;
    if (sel == "add_mslot3")  count = 10;
    if (sel == "add_mslot4")  count = 25;
    if (sel == "add_mslot5")  count = 50;
    if (sel == "add_mslot6")  count = 100;
    if (sel == "add_mslot7")  count = 250;
    if (sel == "add_mslot8")  count = 500;
    if (sel == "add_mslot9")  count = 1000;
    if (sel == "add_mslot10") count = 2500;
    if (sel == "add_mslot11") count = 5000;
    if (sel == "add_mslot12") count = 10000;
    if (count > 0)
    {
        double cost = calc_slot_cost(count, manualSlotBaseCost, manualSlotMultiplier);
        if (coins >= cost)
        {
            coins -= cost;
            manualSlots += count;
            stat_manual_slots_purchased += count;
            for (int i = 0; i < count; i++)
                manualSlotBaseCost *= manualSlotMultiplier;
            pool.destroy_sound(alertslot);
            alertslot = pool.play_stationary("sounds/misc/prodslot.ogg", false);
            speak("Added " + string(count) + " manual " + (count == 1 ? "slot" : "slots") + ". You now have " + string(manualSlots) + " manual " + (manualSlots == 1 ? "slot" : "slots") + ".");
            add_manual_slots();
        }
        else
        {
            alertslot = pool.play_stationary("sounds/dlg/error.ogg", false);
            dlg("Error! You don't have enough coins to add " + string(count) + " manual " + (count == 1 ? "slot" : "slots") + "!");
            pool.destroy_sound(alertslot);
            add_manual_slots();
        }
    }
}
void auto_slots_menu()
{
    setupmenu(false);
    m.add_item("Add a slot", "add");
    m.add_item("Automate a slot", "automate");
    m.add_item("Back", "back");
    int produced = baking_slots.length();
    int automated = autobakeSlots;
    int nonauto = produced - automated;
    m.intro_text = "Auto slots menu. You have " + string(produced) + " produced " + (produced == 1 ? "slot" : "slots") + ", " + string(automated) + " automated " + (automated == 1 ? "slot" : "slots") + ", and " + string(nonauto) + " unautomated " + (nonauto == 1 ? "slot" : "slots") + ".";
    int mres = m.run();
    string selected = m.get_item_id(mres);
    if (mres == -1 || selected == "back")
    {
        manage_baking_slots();
        return;
    }
    if (selected == "add")
    {
        last_menu_id = "";
        add_auto_slots();
        return;
    }
    if (selected == "automate")
    {
        automate_baking_slots();
        return;
    }
}
void manage_baking_slots()
{
    setupmenu(false);
    m.add_item("Auto slots", "auto");
    m.add_item("Manual slots", "manual");
    m.add_item("Back", "back");
    int produced = baking_slots.length();
    int automated = autobakeSlots;
    int nonauto = produced - automated;
    m.intro_text = "Baking slots manager menu. What would you like to do?";
    int mres = m.run();
    string selected = m.get_item_id(mres);
    if (mres == -1 || selected == "back")
    {
        clickergame();
        return;
    }
    if (selected == "manual")
    {
        if (rank < slotManagerUnlockRank)
        {
            gameslot = pool.play_stationary("sounds/misc/gamefail.ogg", false);
            dlg_buffer("Sorry " + playername + ". Manual slots are locked. Please reach rank " + int(slotManagerUnlockRank) + " to use this feature.", "critical");
            manage_baking_slots();
            return;
        }
        last_menu_id = "";
        add_manual_slots();
        return;
    }
    if (selected == "auto")
    {
        if (rank < slotManagerUnlockRank)
        {
            gameslot = pool.play_stationary("sounds/misc/gamefail.ogg", false);
            dlg_buffer("Sorry " + playername + ". Auto slots are locked. Please reach rank " + int(slotManagerUnlockRank) + " to use this feature.", "critical");
            manage_baking_slots();
            return;
        }
        auto_slots_menu();
        return;
    }
}
void automate_baking_slots()
{
        int nonAutoCount = 0;
        for (uint i = 0; i < autobakeSlotEnabled.length(); i++)
        {
            if (!autobakeSlotEnabled[i]) nonAutoCount++;
        }
        if (nonAutoCount == 0)
        {
            alertslot = pool.play_stationary("sounds/dlg/error.ogg", false);
            dlg("Error! There are no slots available to automate.");
            pool.destroy_sound(alertslot);
            auto_slots_menu();
            return;
        }
        setupmenu(false);
        for (uint i = 0; i < autobakeSlotEnabled.length(); i++)
        {
            if (!autobakeSlotEnabled[i])
            {
                m.add_item("Slot " + string(i + 1) + " (unautomated)", "slot" + string(i));
            }
        }
        if (nonAutoCount > 1)
        {
            double totalCost = calc_automation_cost(nonAutoCount, automationBaseCost, automationMultiplier);
            m.add_item("Automate ALL slots for " + format_number(totalCost) + " coins", "automate_all");
        }
        m.add_item("Back", "back");
        m.intro_text = "Slot automation menu.";
        int slotres = m.run();
        if (slotres == -1 || m.get_item_id(slotres) == "back")
        {
            auto_slots_menu();
            return;
        }
        string s = m.get_item_id(slotres);
        if (s == "automate_all")
        {
            double totalCost = calc_automation_cost(nonAutoCount, automationBaseCost, automationMultiplier);
            if (coins >= totalCost)
            {
                coins -= totalCost;
                for (uint i = 0; i < autobakeSlotEnabled.length(); i++)
                {
                    if (!autobakeSlotEnabled[i])
                    {
                        autobakeSlotEnabled[i] = true;
                        autobakeSlots++;
                        automationBaseCost *= automationMultiplier;
                    }
                }
                stat_auto_slots_enabled += nonAutoCount;
                pool.destroy_sound(alertslot);
                alertslot = pool.play_stationary("sounds/misc/autslot.ogg", false);
                speak("Successfully automated " + string(nonAutoCount) + " slot" + (nonAutoCount == 1 ? "" : "s") + ".");
            }
            else
            {
                alertslot = pool.play_stationary("sounds/dlg/error.ogg", false);
                dlg("Error! You don't have enough coins to automate all slots!");
                pool.destroy_sound(alertslot);
            }
            auto_slots_menu();
            return;
        }
        if (s.substr(0, 4) == "slot")
        {
            int index = string_to_int(s.substr(4));
            if (index >= 0 && index < autobakeSlotEnabled.length() && !autobakeSlotEnabled[index])
            {
                setupmenu(false);
                double singleCost = calc_automation_cost(1, automationBaseCost, automationMultiplier);
                m.add_item("Automate this slot for " + format_number(singleCost) + " coins", "automate");
                m.add_item("Preview slot sound", "preview");
                m.add_item("Back", "back");
                m.intro_text = "Slot " + string(index + 1) + " menu.";
                int subres = m.run();
                if (subres == -1 || m.get_item_id(subres) == "back")
                {
                    auto_slots_menu();
                    return;
                }
                if (m.get_item_id(subres) == "preview")
                {
                    pool.play_stationary("sounds/misc/autobake.ogg", false);
                    auto_slots_menu();
                    return;
                }
                if (m.get_item_id(subres) == "automate")
                {
                    if (coins >= singleCost)
                    {
                        coins -= singleCost;
                        autobakeSlotEnabled[index] = true;
                        autobakeSlots++;
                        stat_auto_slots_enabled++;
                        automationBaseCost *= automationMultiplier;
                        pool.destroy_sound(alertslot);
                        alertslot = pool.play_stationary("sounds/misc/autslot.ogg", false);
                        speak("Slot " + string(index + 1) + " is now automated.");
                    }
                    else
                    {
                        alertslot = pool.play_stationary("sounds/dlg/error.ogg", false);
                        dlg("Error! You don't have enough coins to automate this slot!");
                        pool.destroy_sound(alertslot);
                    }
                    auto_slots_menu();
                    return;
                }
            }
        }
}

void questsmenu()
{
    form.reset();
    form.create_window("Quests", false);
    int questList = form.create_list("&Quests", 0, false, false);
    for (uint i = 0; i < activeQuests.length(); i++)
    {
        form.add_list_item(questList, activeQuests[i].name, activeQuests[i].id, -1, true);
    }
    int detailBox = form.create_input_box("&Quest details", "", read_only:true, multiline:true);
    double rerollCost = floor(questsConfig.reroll_base_cost * pow(questsConfig.reroll_multiplier, questRerollCount));
    int rerollBtn = -1;
    int closeBtn = form.create_button("&Close", false, true);
    form.focus(questList);
    form.set_list_position(questList, 0);
    int lastPos = -1;
    bool lastRequired = true;
    while (true)
    {
        wait(5);
        form.monitor();
        int curPos = form.get_list_position(questList);
        if (curPos != lastPos && curPos >= 0 && curPos < int(activeQuests.length()))
        {
            form.set_text(detailBox, get_quest_detail(activeQuests[curPos]));
            bool isRequired = activeQuests[curPos].required;
            if (isRequired != lastRequired)
            {
                if (rerollBtn != -1) form.delete_control(rerollBtn);
                form.delete_control(closeBtn);
                if (!isRequired)
                    rerollBtn = form.create_button("&Reroll quest for " + format_number(rerollCost) + " " + questsConfig.reroll_target);
                else
                    rerollBtn = -1;
                closeBtn = form.create_button("&Close", false, true);
                lastRequired = isRequired;
                form.focus_silently(questList);
            }
            lastPos = curPos;
        }
        if (rerollBtn != -1 && form.is_pressed(rerollBtn))
        {
            int rerollPos = form.get_list_position(questList);
            if (rerollPos < 0 || rerollPos >= int(activeQuests.length()))
            {
                form.reset();
                questsmenu();
                return;
            }
            double rerollConfirmCost = floor(questsConfig.reroll_base_cost * pow(questsConfig.reroll_multiplier, questRerollCount));
            double rerollStatVal = 0;
            if (questsConfig.reroll_target == "coins")           rerollStatVal = coins;
            else if (questsConfig.reroll_target == "cookies")    rerollStatVal = cookies;
            else if (questsConfig.reroll_target == "autocooky")  rerollStatVal = autocooky;
            else if (questsConfig.reroll_target == "manulcooky") rerollStatVal = manulcooky;
            else if (questsConfig.reroll_target == "cookyspeed") rerollStatVal = cookyspeed;
            if (rerollStatVal < rerollConfirmCost)
            {
                double rerollShortfall = rerollConfirmCost - rerollStatVal;
                string rerollUnit = questsConfig.reroll_target;
                if (rerollShortfall == 1)
                {
                    if (rerollUnit == "coins")           rerollUnit = "coin";
                    else if (rerollUnit == "cookies")    rerollUnit = "cookie";
                    else if (rerollUnit == "autocooky")  rerollUnit = "auto cooky";
                    else if (rerollUnit == "manulcooky") rerollUnit = "manual cooky";
                    else if (rerollUnit == "cookyspeed") rerollUnit = "cooky speed";
                }
                else
                {
                    if (rerollUnit == "autocooky")       rerollUnit = "auto cookies";
                    else if (rerollUnit == "manulcooky") rerollUnit = "manual cookies";
                    else if (rerollUnit == "cookyspeed") rerollUnit = "cooky speeds";
                }
                dlgmessage_return("You cannot afford to reroll this quest. You need " + format_number(rerollShortfall) + " more " + rerollUnit + " to do this.");
                form.reset();
                questsmenu();
                return;
            }
            setupmenu(false);
            m.add_item("Yes", "yes");
            m.add_item("No", "no");
            m.intro_text = "Are you sure you want to reroll this quest? This action cannot be undone.";
            int mres = m.run();
            if (mres == -1 || m.get_item_id(mres) == "no")
            {
                form.reset();
                questsmenu();
                return;
            }
            reroll_quest(rerollPos);
            form.reset();
            questsmenu();
            return;
        }
        if (form.is_pressed(closeBtn) || key_pressed(KEY_ESCAPE))
        {
            form.reset();
            clickergame();
            return;
        }
    }
}

void start_prestige()
{
    setupmenu(false);
    m.add_item("Yes", "yes");
    m.add_item("No", "no");
    m.intro_text = "Are you sure you want to prestige? Your cookies, coins, rank, upgrades, and baking slots will be reset. Your achievements, minigame stats, and prestige bonus will be kept.";
    int mres = m.run();
    if (mres == -1 || m.get_item_id(mres) == "no")
    {
        form.reset();
        clickergame();
        return;
    }
    ambpool.pause_sound(ambslot);
    muspool.pause_sound(mustrackslot);
    writedata();
    resetgame(true);
    writedata();
    ambpool.resume_sound(ambslot);
    muspool.resume_sound(mustrackslot);
    form.reset();
    clickergame();
}

void preffsmenu()
{
form.reset();
    form.create_window("preferences", false);
    int audsets = form.create_button("&audio settings");
int gamsets = form.create_button("&game settings");
int usersets = form .create_button("&user settings");
form.focus(audsets);
    while (true)
    {
        form.monitor();
        wait(5);
        if (form.is_pressed(gamsets))
        {
gamsetsmenu();
}
        if (form.is_pressed(audsets))
        {
soundsetsmenu();
}
        if (form.is_pressed(usersets))
        {
usersetsmenu();
}
        if (key_pressed(KEY_ESCAPE))
        {
if(ingame==true)
{
form.reset();
clickergame();
}
else if(ingame==false)
{
mainmenu();
}
    }
}
}
void gamsetsmenu()
{
    form.reset();
    form.create_window("Game Settings", false);
int logoSFX = form.create_checkbox("Enable playing the logo sound upon launching the game.", logosfx);
int introSFX = form.create_checkbox("Enable playing the intro sound upon starting the game.", introsfx);
int exitSFX = form.create_checkbox("Enable playing the exit sound upon exiting the game.", exitsfx);
int bakeSFX = form.create_checkbox("Enable auto bake sound effects when baking cookies.", bakesfx);
int coinSFX = form.create_checkbox("Enable coin sound effects when earning money.", coinsfx);
int eventSFX = form.create_checkbox("Enable event sound effects when events trigger.", eventsfx);
int achSFX = form.create_checkbox("Enable achievement sound effects when unlocking achievements.", achsfx);
int rankSFX = form.create_checkbox("Enable rank sound effects when leveling up.", ranksfx);
int saveSFX = form.create_checkbox("Enable save sound effects when reloading and saving the game.", savesfx);
int playvents = form.create_checkbox("Enable player events during auto baking.", playervents);
int playvents2 = form.create_checkbox("Enable player events during manual baking.", playervents2);
int ordsyms = form.create_checkbox("Enable alphabetical symbol listing for the slot machine mini game.", orderedSyms);
int reelspin = form.create_checkbox("Enable automatic stopping of reels for the slot machine mini game.", slotmode);
int jackautodraw = form.create_checkbox("Enable automatic card drawing for the blackjack mini game.", jackmode);
int bakeSplitToggle = form.create_checkbox("Enable evenly distributing cookie production across automated slots.", slotDistribution);
int manualBakeSplitToggle = form.create_checkbox("Enable evenly distributing cookie production across manual slots.", manualSlotDistribution);
int automationMultiplierSlider = form.create_slider("Automation slot Cost Multiplier.", round((automationMultiplier - 1.0) * 100, 0), 1, 100, "X", 1);
int slotMultiplierSlider = form.create_slider("Auto slot production Cost Multiplier.", round((slotMultiplier - 1.0) * 100, 0), 1, 100, "X", 1);
int manualSlotMultiplierSlider = form.create_slider("Manual slot production Cost Multiplier.", round((manualSlotMultiplier - 1.0) * 100, 0), 1, 100, "X", 1);
int cookieRankModifierSlider = form.create_slider("Cookie Rank Modifier.", cookymod, 1, 100, "x", 1);
int difficultyRankModifierSlider = form.create_slider("Difficulty rank Modifier.", difmod, 1, 100, "x", 1);
int autoChanceSlider = form.create_slider("Auto-Baking Event chance.", 100 - evchanse, 0, 100, "percent", 1);
int manualChanceSlider = form.create_slider("Manual-Baking Event chance.", 100 - evchanse2, 0, 100, "percent", 1);
int savesets = form.create_button("&save settings", true);
int cansets = form.create_button("&cancel");
form.focus(introSFX);
    while (true)
    {
        wait(5);
        form.monitor();
automationMultiplier = 1.0 + (form.get_slider(automationMultiplierSlider) * 0.01);
slotMultiplier = 1.0 + (form.get_slider(slotMultiplierSlider) * 0.01);
manualSlotMultiplier = 1.0 + (form.get_slider(manualSlotMultiplierSlider) * 0.01);
cookymod = form.get_slider(cookieRankModifierSlider);
difmod = form.get_slider(difficultyRankModifierSlider);
evchanse = 100 - form.get_slider(autoChanceSlider);
evchanse2 = 100 - form.get_slider(manualChanceSlider);
introsfx = form.is_checked(introSFX);
logosfx = form.is_checked(logoSFX);
exitsfx = form.is_checked(exitSFX);
bakesfx = form.is_checked(bakeSFX);
        coinsfx = form.is_checked(coinSFX);
eventsfx = form.is_checked(eventSFX);
        ranksfx = form.is_checked(rankSFX);
achsfx = form.is_checked(achSFX);
savesfx = form.is_checked(saveSFX);
slotDistribution = form.is_checked(bakeSplitToggle);
manualSlotDistribution = form.is_checked(manualBakeSplitToggle);
        playervents = form.is_checked(playvents);
        playervents2 = form.is_checked(playvents2);
orderedSyms = form.is_checked(ordsyms);
slotmode = form.is_checked(reelspin);
jackmode = form.is_checked(jackautodraw);
        if (form.is_pressed(savesets))
        {
writepreffs();
            dlgmessage_return("Settings saved.");
writedata();
readdata();
            preffsmenu();
        }
if (key_pressed(KEY_ESCAPE))
        {
preffsmenu();
}
            if (form.is_pressed(cansets))
        {
preffsmenu();
}
}
}
void soundsetsmenu()
{
form.reset();
    form.create_window("audio settings", false);
int amblist, musslist;
if(ingame==true) amblist = form.create_list("ambience sound:", 4);
if(ingame==true) musslist = form.create_list("music track:", 20);
    string[] ambOptions;
    for (uint i = 1; i <= 4; i++)
    {
        string ambName = "Room " + i;
        string ambID = "room" + i;
        ambOptions.insert_last(ambID);
        form.add_list_item(amblist, ambName, ambID);
    }
    string[] musOptions;
    for (uint i = 1; i <= 20; i++)
    {
        string musName = "Music " + i;
        string musID = "music" + i;
        musOptions.insert_last(musID);
        form.add_list_item(musslist, musName, musID);
    }
if(ingame==true) form.set_list_position(amblist, ambienceIndex);
if(ingame==true) form.set_list_position(musslist, musicIndex);
int gameAmbienceVolumeSlider = form.create_slider("game ambience volume, ", (ambvolume + 50) * 2, 0, 100, "percent", 1);
int gameMusicVolumeSlider = form.create_slider("game music volume, ", (musvolume + 50) * 2, 0, 100, "percent", 1);
int storeAmbienceVolumeSlider = form.create_slider("store ambience volume, ", (storambvolume + 50) * 2, 0, 100, "percent", 1);
int storeMusicVolumeSlider = form.create_slider("store music volume, ", (stormusvolume + 50) * 2, 0, 100, "percent", 1);
int savesets = form.create_button("&save settings", true);
int cansets = form.create_button("&cancel");
form.focus(amblist);
    while (true)
    {
        wait(5);
        form.monitor();
ambvolume = (form.get_slider(gameAmbienceVolumeSlider) / 2) - 50;
musvolume = (form.get_slider(gameMusicVolumeSlider) / 2) - 50;
storambvolume = (form.get_slider(storeAmbienceVolumeSlider) / 2) - 50;
stormusvolume = (form.get_slider(storeMusicVolumeSlider) / 2) - 50;
        ambpool.update_sound_start_values(ambslot, 0, ambvolume, ambpitch);
        muspool.update_sound_start_values(mustrackslot, 0, musvolume, muspitch);
storambpool.update_sound_start_values(storambslot, 0, storambvolume, storambpitch);
stormuspool.update_sound_start_values(stortrackslot, 0, stormusvolume, stormuspitch);
if(ingame==true) ambienceIndex = form.get_list_position(amblist);
        if (ambienceIndex != -1 && ambOptions[ambienceIndex] != ambtype)
        {
            ambtype = ambOptions[ambienceIndex];
            ambpool.destroy_sound(ambslot);
            ambslot = ambpool.play_stationary_extended("sounds/misc/"+ambtype + ".ogg", true, 0, 0, ambvolume, ambpitch, false);
        }
if(ingame==true) musicIndex = form.get_list_position(musslist);
        if (musicIndex != -1 && musOptions[musicIndex] != mustype)
        {
            mustype = musOptions[musicIndex];
            muspool.destroy_sound(mustrackslot);
            mustrackslot = muspool.play_stationary_extended("sounds/misc/"+mustype + ".ogg", true, 0, 0, musvolume, muspitch, false);
        }
        if (form.is_pressed(savesets))
        {
writepreffs2();
dlgmessage_return("Settings saved.");
preffsmenu();
}
        if (key_pressed(KEY_ESCAPE))
        {
preffsmenu();
}
            if (form.is_pressed(cansets))
        {
preffsmenu();
}
    }
}
void usersetsmenu()
{
    string gendertext;
    if (playergender == 0)
{
        gendertext = "Male";
    }
else if (playergender == 1)
{
        gendertext = "Female";
    }
else if (playergender == 2)
{
        gendertext = "Non-binary";
    }
else
{
        gendertext = "Unknown";
    }
    form.reset();
    form.create_window("User Settings", false);
    int charname = form.create_button("Change the character's &first name. Currently set to "+playername+".");
    int charname2 = form.create_button("Change the character's &last name. Currently set to "+playername2+".");
    int chargender = form.create_list("Change the character's &gender. Currently set to " + gendertext + ".", 3);
    form.add_list_item(chargender, "Male");
    form.add_list_item(chargender, "Female");
    form.add_list_item(chargender, "Non-binary");
    if (playergender >= 0 && playergender <= 2)
{
        form.set_list_position(chargender, playergender);
    }
int savesets = form.create_button("&save settings", true);
int cansets = form.create_button("&cancel");
form.focus(charname);
    while (true)
    {
        form.monitor();
        wait(5);
playergender = form.get_list_position(chargender);
        if (form.is_pressed(charname))
        {
vd.set_disallowed_chars(" !@#$%^&*()[]{};:'\"\\|,.<>?/+-=`~", false, "This character is not allowed.");
string fn=vd.input_box("","Enter the first name of this character.");
if(fn.is_empty())
{
alertslot=pool.play_stationary("sounds/dlg/error.ogg",false);
dlg("Error! Your character's first name is invalid!");
pool.destroy_sound(alertslot);
            form.reset();
            usersetsmenu();
}
else
{
playername=fn;
            dlgmessage_return("Success! Your character's first name has now been changed to "+playername+".");
            form.reset();
            usersetsmenu();
}
}
        if (form.is_pressed(charname2))
        {
vd.set_disallowed_chars(" !@#$%^&*()[]{};:'\"\\|,.<>?/+-=`~", false, "This character is not allowed.");
string fn2=vd.input_box("","Enter the last name of this character.");
if(fn2.is_empty())
{
pool.play_stationary("sounds/dlg/error.ogg",false);
dlg("Error! Your character's last name is invalid!");
pool.destroy_sound(alertslot);
            form.reset();
            usersetsmenu();
}
else
{
playername2=fn2;
            dlgmessage_return("Success! Your character's last name has now been changed to "+playername2+".");
            form.reset();
            usersetsmenu();
}
}
        if (form.is_pressed(savesets))
        {
            writepreffs3();
            dlgmessage_return("Settings saved.");
preffsmenu();
        }
        if (key_pressed(KEY_ESCAPE))
        {
preffsmenu();
}
            if (form.is_pressed(cansets))
        {
preffsmenu();
}
    }
}
