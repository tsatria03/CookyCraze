void slot_wait_async(int milliseconds)
{
    timer WaitTimer;
    WaitTimer.restart();
    while (WaitTimer.elapsed < milliseconds)
    {
        wait(5);
        form.monitor();
int betChoice, betInput, symbolChoices;
if(form.get_current_focus()!=betChoice and form.get_current_focus()!=betInput and form.get_current_focus()!=symbolChoices) slots_game_input();
        key_code[] keys = keys_pressed();
        for (uint i = 0; i < keys.length(); i++)
        {
            key_code key = keys[i];
        }
    }
}

void jack_wait_async(int milliseconds)
{
    timer WaitTimer;
    WaitTimer.restart();
    while (WaitTimer.elapsed < milliseconds)
    {
        wait(5);
        form.monitor();
        int betChoice, betInput;
        if (form.get_current_focus() != betChoice && form.get_current_focus() != betInput) jack_game_input();
        key_code[] keys = keys_pressed();
        for (uint i = 0; i < keys.length(); i++)
        {
            key_code key = keys[i];
        }
    }
}

void jack_deal_card(bool to_player, int&inout p_points, int&inout p_aces, int&inout d_points, int&inout d_aces)
{
    int r = random(1, 13);
    int s = random(1, 4);
    int v = (r == 1 ? 11 : (r >= 11 ? 10 : r));
    string rname = (r == 1 ? "Ace" : (r == 11 ? "Jack" : (r == 12 ? "Queen" : (r == 13 ? "King" : string(r)))));
    string sname = (s == 1 ? "Hearts" : (s == 2 ? "Diamonds" : (s == 3 ? "Clubs" : "Spades")));
    if (to_player)
    {
        pool.play_stationary("sounds/misc/" + resolve_sound(jacksConfig.player_draw_sound), false);
        p_points += v;
        if (v == 11) p_aces++;
        while (p_points > 21 && p_aces > 0)
        {
            p_points -= 10;
            p_aces--;
        }
        if (jackmode) speak_buffer("You drew a " + rname + " of " + sname + ", for a total of " + p_points + ".");
        else dlg_buffer("You drew a " + rname + " of " + sname + ", for a total of " + p_points + ".");
    }
    else
    {
        pool.play_stationary("sounds/misc/" + resolve_sound(jacksConfig.dealer_draw_sound), false);
        d_points += v;
        if (v == 11) d_aces++;
        while (d_points > 21 && d_aces > 0)
        {
            d_points -= 10;
            d_aces--;
        }
        if (jackmode) speak_buffer("Dealer drew a " + rname + " of " + sname + ", for a total of " + d_points + ".");
        else dlg_buffer("Dealer drew a " + rname + " of " + sname + ", for a total of " + d_points + ".");
    }
}
