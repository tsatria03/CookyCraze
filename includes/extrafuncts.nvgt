void minigame_input(string game)
{
    buffer_check_keys();
    if (key_pressed(KEY_C)) speak_buffer("You have " + format_number(cookies) + " cookies.");
    if (key_pressed(KEY_A)) speak_buffer("You have " + format_number(autocookie) + " auto cookies.");
    if (key_pressed(KEY_S)) speak_buffer("You have " + format_number(cookiespeed) + " auto cookie speeds.");
    if (key_pressed(KEY_M)) speak_buffer("You have " + format_number(manulcookie) + " manual cookies.");
    if (key_pressed(KEY_O))
    {
        pool.destroy_sound(coinslot);
        if (coins > 0) coinslot = pool.play_stationary("sounds/misc/cointoss.ogg", false);
        speak_buffer("You have " + convert_to_currency(coins) + ".");
    }
    if (control_is_down())
    {
        if (key_pressed(KEY_S))
        {
            writedata();
            ambpool.pause_sound(ambslot);
            muspool.pause_sound(mustrackslot);
            speak_buffer("game saved", "misc");
            if (savesfx == false) wait(500);
            if (savesfx == true) dlgplay("sounds/misc/savegame.ogg");
            ambpool.resume_sound(ambslot);
            muspool.resume_sound(mustrackslot);
            form.reset();
            if (game == "flipper")        flipgame();
            else if (game == "slots")     slotsgame();
            else if (game == "blackjack") jackgame();
            else if (game == "lottery")   lotterygame();
            else if (game == "dice")      dicegame();
        }
        if (key_pressed(KEY_L))
        {
            readdata();
            reload_config(true);
            ambpool.pause_sound(ambslot);
            muspool.pause_sound(mustrackslot);
            speak_buffer("game reloaded", "misc");
            if (savesfx == false) wait(500);
            if (savesfx == true) dlgplay("sounds/misc/savegame.ogg");
            ambpool.resume_sound(ambslot);
            muspool.resume_sound(mustrackslot);
            form.reset();
            if (game == "flipper")        flipgame();
            else if (game == "slots")     slotsgame();
            else if (game == "blackjack") jackgame();
            else if (game == "lottery")   lotterygame();
            else if (game == "dice")      dicegame();
        }
    }
}
void mini_wait_async(int milliseconds, string minigame)
{
    timer WaitTimer;
    WaitTimer.restart();
    while (WaitTimer.elapsed < milliseconds)
    {
        wait(5);
        form.monitor();
        minigame_input(minigame);
    }
}

void jack_deal_card(bool to_player, int&inout p_points, int&inout p_aces, int&inout d_points, int&inout d_aces)
{
    int r = random(1, 13);
    int s = random(1, 4);
    int v = (r == 1 ? 11 : (r >= 11 ? 10 : r));
    string rname = (r == 1 ? "Ace" : (r == 11 ? "Jack" : (r == 12 ? "Queen" : (r == 13 ? "King" : string(r)))));
    string sname = (s == 1 ? "Hearts" : (s == 2 ? "Diamonds" : (s == 3 ? "Clubs" : "Spades")));
    if (to_player)
    {
        pool.play_stationary("sounds/minigames/" + resolve_sound(jacksConfig.player_draw_sound), false);
        p_points += v;
        if (v == 11) p_aces++;
        while (p_points > 21 && p_aces > 0)
        {
            p_points -= 10;
            p_aces--;
        }
        if (jackmode) speak_buffer("You drew a " + rname + " of " + sname + ", for a total of " + p_points + ".");
        else dlg_buffer("You drew a " + rname + " of " + sname + ", for a total of " + p_points + ".");
    }
    else
    {
        pool.play_stationary("sounds/minigames/" + resolve_sound(jacksConfig.dealer_draw_sound), false);
        d_points += v;
        if (v == 11) d_aces++;
        while (d_points > 21 && d_aces > 0)
        {
            d_points -= 10;
            d_aces--;
        }
        if (jackmode) speak_buffer("Dealer drew a " + rname + " of " + sname + ", for a total of " + d_points + ".");
        else dlg_buffer("Dealer drew a " + rname + " of " + sname + ", for a total of " + d_points + ".");
    }
}
