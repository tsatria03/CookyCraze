int string_to_int(string str)
{
    int result = 0;
    bool isNegative = false;
    if (str.length() == 0)
        return 0;
    if (str.substr(0, 1) == "-")
    {
        isNegative = true;
        str = str.substr(1);
    }
    for (uint i = 0; i < str.length(); i++)
    {
        string digitStr = str.substr(i, 1);
        int digit = 0;
        if (digitStr == "0") digit = 0;
        else if (digitStr == "1") digit = 1;
        else if (digitStr == "2") digit = 2;
        else if (digitStr == "3") digit = 3;
        else if (digitStr == "4") digit = 4;
        else if (digitStr == "5") digit = 5;
        else if (digitStr == "6") digit = 6;
        else if (digitStr == "7") digit = 7;
        else if (digitStr == "8") digit = 8;
        else if (digitStr == "9") digit = 9;
        else return 0;
        result = result * 10 + digit;
    }
    return isNegative ? -result : result;
}

string format_number(double num, bool basic=false, bool scientific=false, bool short_suffix=true)
{
    if (num == 0)
        return "0";
    double absNum = abs(num);
    if (absNum > 1e308)
        return "Inf";
    if (scientific && absNum >= 1000000)
    {
        int exponent = floor(log10(absNum));
        double mantissa = num * pow(10, -exponent);
        string sign="+";
        if (exponent < 0) sign="";
        return round(mantissa,2) + "e" + sign + exponent;
    }
    if (basic || absNum < 1000)
    {
        string str = round(num, absNum < 10 ? 2 : 0);
        bool negative=false;
        if (str.substr(0,1)=="-")
        {
            negative=true;
            str=str.substr(1);
        }
        string integerPart=str;
        string decimalPart="";
        int dot=str.find(".");
        if(dot!=-1)
        {
            integerPart=str.substr(0,dot);
            decimalPart=str.substr(dot);
        }
        string result="";
        int count=0;
        for(int i=int(integerPart.length())-1;i>=0;i--)
        {
            result=integerPart.substr(i,1)+result;
            count++;
            if(count%3==0 && i>0)
                result=","+result;
        }
        if(negative) result="-"+result;
        return result+decimalPart;
    }
    string[] suffix_short={
        "K","M","B","T",
        "Qa","Qi","Sx","Sp","Oc",
        "No","Dc","Ud","Dd","Td",
        "Qad","Qid","Sxd","Spd","Ocd",
        "Nod","Vg","Uvg","Dvg","Tvg"
    };
    string[] suffix_speech={
        "k","m","b","t",
        "qua","qui","sext","sep","oct",
        "non","dec","und","duo","tre",
        "quat","quin","sexd","sepd","octd",
        "nond","vig","unvig","duovig","trevig"
    };
    int tier = int(floor(log10(absNum)/3)) - 1;
    if (tier < 0) tier = 0;
    int maxTier = suffix_short.length()-1;
    if (tier > maxTier)
    {
        int exponent = floor(log10(absNum));
        double mantissa = num * pow(10,-exponent);
        return round(mantissa,2) + "e+" + exponent;
    }
    double scale = pow(10,(tier+1)*3);
    if (scale == 0)
        return "Inf";
    double value = num / scale;
    if (round(value, 2) >= 1000.0 && tier < maxTier)
    {
        tier++;
        scale = pow(10,(tier+1)*3);
        value = num / scale;
    }
    if (short_suffix)
        return round(value,2) + suffix_short[tier];
    else
        return round(value,2) + suffix_speech[tier];
}

double apply_amount_effect(string target, double amount, int polarity, bool use_percent)
{
    double base = 0;
    if (target == "coins")           base = coins;
    else if (target == "cookies")    base = cookies;
    else if (target == "autocookie")  base = autocookie;
    else if (target == "manulcookie") base = manulcookie;
    else return 0;
    if (use_percent && base <= 0) return 0;
    if (polarity == 2 && base < 1) return 0;
    double actual = use_percent ? base * (amount / 100.0) : amount;
    actual = max(1.0, floor(actual));
    if (polarity == 1)
    {
        if (target == "coins")           { coins += actual; stat_coins_earned += actual; }
        else if (target == "cookies")    cookies += actual;
        else if (target == "autocookie")  autocookie += actual;
        else if (target == "manulcookie") manulcookie += actual;
    }
    else
    {
        actual = min(actual, base);
        if (target == "coins")           coins -= actual;
        else if (target == "cookies")    cookies -= actual;
        else if (target == "autocookie")  autocookie = max(0, autocookie - actual);
        else if (target == "manulcookie") manulcookie = max(0, manulcookie - actual);
    }
    return actual;
}

string format_template(string msg, dictionary@ replacements)
{
    string[] keys = replacements.get_keys();
    for (uint k = 0; k < keys.length(); k++)
    {
        string key = "%" + keys[k] + "%";
        string val;
        replacements.get(keys[k], val);
        int ph = msg.find(key);
        while (ph != -1)
        {
            msg = msg.substr(0, ph) + val + msg.substr(ph + key.length());
            ph = msg.find(key);
        }
    }
    return msg;
}

string[] parse_delimited_line(string line, int max_parts, string delimiter = ":")
{
    string[] parts;
    int lastPos = 0;
    int count = 0;
    for (uint i = 0; i < line.length(); i++)
    {
        if (line.substr(i, 1) == delimiter && count < max_parts)
        {
            parts.insert_last(line.substr(lastPos, int(i) - lastPos));
            lastPos = int(i) + 1;
            count++;
        }
    }
    parts.insert_last(line.substr(lastPos));
    return parts;
}

string to_string(int value)
{
    return "" + value;
}
double convert_to_pan(double length, double index, double range1, double range2)
{
try
{
double range = range2 - range1;
double percent = index / (length - 1);
double value = range1 + range * percent;
return value;
}
catch
{
return 0;
}
}
double convert_to_volume(double length,double index,double min_volume=-100,double max_volume=0)
{
try
{
double range=max_volume-min_volume;
double percent=index/(length-1);
double value=min_volume+range*percent;
return value;
}
catch
{
return 0;
}
}
double convert_to_pitch(double length,double index,double min_pitch=0,double max_pitch=200)
{
try
{
double range=max_pitch-min_pitch;
double percent=index/(length-1);
double value=min_pitch+range*percent;
return value;
}
catch
{
return 100;
}
}


string convert_to_currency(double number, string currency_symbol = "$")
{
    if (number < 0) return "";
    double rounded = floor(number + 0.5);
    double dollars = floor(rounded / 100.0);
    int cents = int(rounded - (dollars * 100.0));
    if (dollars == 0)
        return cents + " cent" + (cents == 1 ? "" : "s");
    if (dollars >= 1000)
        return currency_symbol + format_number(dollars);
    string cents_str = "" + cents;
    if (string_len(cents_str) == 1) cents_str = "0" + cents_str;
    return currency_symbol + format_number(dollars) + "." + cents_str;
}

string resolve_sound(string raw)
{
    int open = raw.find("(");
    int close = raw.find(")");
    if (open != -1 && close != -1 && close > open)
    {
        string before = raw.substr(0, open);
        string after = raw.substr(close + 1);
        string range = raw.substr(open + 1, close - open - 1);
        int comma = range.find(",");
        if (comma != -1)
        {
            int minVal = string_to_int(range.substr(0, comma));
            int maxVal = string_to_int(range.substr(comma + 1));
            return before + string(random(minVal, maxVal)) + after;
        }
    }
    return raw;
}

string resolve_sound_path(string raw, string default_folder)
{
    string resolved = resolve_sound(raw);
    if (resolved.find("/") != -1)
        return "sounds/" + resolved;
    return "sounds/" + default_folder + "/" + resolved;
}

double eval_event_amount(string raw, double rank_val)
{
    if (raw.find("*rank") != -1)
    {
        string numPart = raw.substr(0, raw.find("*rank"));
        return string_to_number(numPart) * rank_val;
    }
    else if (raw.find("/rank") != -1)
    {
        string numPart = raw.substr(0, raw.find("/rank"));
        double divisor = rank_val;
        if (divisor == 0) divisor = 1;
        return string_to_number(numPart) / divisor;
    }
    else if (raw.find("+rank") != -1)
    {
        string numPart = raw.substr(0, raw.find("+rank"));
        return string_to_number(numPart) + rank_val;
    }
    else if (raw.find("-rank") != -1)
    {
        string numPart = raw.substr(0, raw.find("-rank"));
        return string_to_number(numPart) - rank_val;
    }
    return string_to_number(raw);
}

string random_string(string[] array)
{
string retval=array[random(0,array.length()-1)];
return retval;
}

void dockread(const string&in filename)
{
if(!file_exists(filename))
{
alert("Error","Could not fined "+string_replace(filename, "docks/", "", true));
docksmenu();
}
dockfile.open(filename,"rb");
string docktext=dockfile.read();
dockfile.close();
form.reset();
form.create_window("Viewing "+string_replace(filename, "docks/", "", true),false,false,false);
int dockbox=form.create_input_box(string_replace(filename, "docks/", "", true), docktext, read_only:true, multiline:true);
int dockclose=form.create_button("&close",false,true);
form.focus(dockbox);
while(true)
{
wait(5);
form.monitor();
if (form.is_pressed(dockclose))
{
docksmenu();
}
}
}

void play_coin_sound(double amount)
{
    string snd = "";
    if (amount > 0 && amount < 10) snd = "coin1.ogg";
    else if (amount >= 10 && amount <= 490) snd = "coin1.ogg";
    else if (amount >= 500 && amount <= 9990) snd = "coin50.ogg";
    else if (amount >= 10000 && amount <= 99990) snd = "coin1000.ogg";
    else if (amount >= 100000 && amount <= 499990) snd = "coin10000.ogg";
    else if (amount >= 500000 && amount <= 999990) snd = "coin50000.ogg";
    else if (amount >= 1000000) snd = "coin100000.ogg";
    if (snd != "") pool.play_stationary("sounds/store/" + snd, false);
}

void reload_config(bool force = false)
{
    if (config_loaded && !force) return;
    loadedEvents = parse_baker_events("data/config/events/baker.event");
    loadedFlipperEvents = parse_flipper_items("data/config/events/flipper.event");
    slotSymbols.resize(0); slotPayouts.resize(0);
    parse_slots_table("data/config/tables/slots.table", slotSymbols, slotPayouts, slotReels, slotMinBet, slotMaxBet, slotConfirmThreshold, slotConfirmUsePercent);
    rankSounds.resize(0); rankDefault.resize(0); rankRewards.resize(0);
    parse_ranks_table("data/config/tables/ranks.table", rankSounds, rankDefault, rankRewards);
    parse_jacks_table("data/config/tables/jacks.table", jacksConfig);
    parse_dice_table("data/config/tables/dice.table");
    parse_combos_table("data/config/tables/combos.table", combosConfig);
    parse_lottery_table("data/config/tables/lottery.table");
    loadedAchievements.resize(0);
    loadedAchievementCategories.resize(0);
    parse_achievements("data/config/tables/achievements.table", loadedAchievements, loadedAchievementCategories);
    achievementsUnlocked.delete_all();
    init_achievements(loadedAchievements, achievementsUnlocked);
    parse_prestige_table("data/config/tables/prestige.table");
    loadedQuests.resize(0);
    parse_quests_table("data/config/tables/quests.table", loadedQuests);
    assign_quests();
    apply_all_prestige_store_upgrades();
    config_loaded = true;
}


void show_baker_info()
{
    string txt = "";
    txt += "Production\r\n";
    txt += "Auto cookies: " + format_number(autocookie) + "\r\n";
    txt += "Manual cookies: " + format_number(manulcookie) + "\r\n";
    txt += "Baking speed reduction: " + format_number(cookiespeed) + "ms\r\n";
    txt += "Bake interval: " + format_number(max(0.0, 1000.0 - cookiespeed)) + "ms\r\n";
    txt += "\r\n";
    txt += "Slots\r\n";
    txt += "Auto slots: " + string(autobakeSlots) + "\r\n";
    txt += "Manual slots: " + string(manualSlots) + "\r\n";
    txt += "\r\n";
    txt += "Progress\r\n";
    txt += "Current rank: " + format_number(rank) + "\r\n";
    txt += "Current cookies: " + format_number(cookies) + "\r\n";
    txt += "Cookies needed for next rank: " + format_number(max(0.0, cookiesrequiered - cookies)) + "\r\n";
    txt += "Current balance: " + convert_to_currency(coins) + "\r\n";
    txt += "Cookie sell price: " + convert_to_currency(cookieSellPrice) + " each\r\n";
    txt += "Earnings per sell: " + convert_to_currency(floor(cookies) * cookieSellPrice) + "\r\n";
    txt += "Prestige level: " + string(prestigeLevel) + "\r\n";
    int completedQuests = 0;
    for (uint i = 0; i < activeQuests.length(); i++)
    {
        if (get_stat_value(activeQuests[i].stat) >= activeQuests[i].threshold) completedQuests++;
    }
    string questRewardMode = "";
    if (questsConfig.require_all == 1) questRewardMode = "Reward fires if any quest happens to be complete";
    else if (questsConfig.require_all == 2) questRewardMode = "At least one quest must be complete";
    else if (questsConfig.require_all == 3) questRewardMode = "All " + string(activeQuests.length()) + " quests must be complete";
    txt += "Prestige reward condition: " + questRewardMode + "\r\n";
    txt += "Quests completed: " + string(completedQuests) + " of " + string(activeQuests.length()) + "\r\n";
    form.reset();
    form.create_window("Baker info", false);
    int infobox = form.create_input_box("Baker info", txt, read_only:true, multiline:true);
    int infoclose = form.create_button("&Close", false, true);
    form.focus(infobox);
    while (true)
    {
        wait(5);
        form.monitor();
        if (form.is_pressed(infoclose))
        {
            form.reset();
            clickergame();
            return;
        }
    }
}

