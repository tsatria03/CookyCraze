}

double clamp(double value, double min, double max)
{
value=value<min? min:value;
value=value>max? max:value;
return value;
}
double min(double a, double b)
{
return (a < b) ? a : b;
}
double max(double a, double b)
{
return (a > b) ? a : b;
}
double safe_cap(double value)
{
    if (value != value) return 1e308;
    return clamp(value, 0, 1e308);
}
double buy_item(double level, double base_cost, double multiplier)
{
    return safe_cap(base_cost * pow(multiplier, level));
}
double calc_max_buyable(double coins, double level, double base_cost, double multiplier)
{
    double currentCost = safe_cap(base_cost * pow(multiplier, level));
    if (currentCost <= 0) return 0;
    if (multiplier <= 1.000001)
        return floor(coins / currentCost);
    double result = floor(log(1 + (coins * (multiplier - 1)) / currentCost) / log(multiplier));
    if (result < 0 || result != result) result = 0;
    return result;
}
double calc_total_upgrade_cost(double level, double quantity, double base_cost, double multiplier)
{
    double startCost = safe_cap(base_cost * pow(multiplier, level));
    if (multiplier <= 1.000001)
        return safe_cap(startCost * quantity);
    return safe_cap(startCost * (pow(multiplier, quantity) - 1) / (multiplier - 1));
}
double calc_automation_cost(double count, double baseCost, double multiplier)
{
    if (multiplier <= 1.000001)
        return safe_cap(baseCost * count);
    return safe_cap(baseCost * (pow(multiplier, count) - 1) / (multiplier - 1));
}
double calc_slot_cost(double count)
{
    if (slotMultiplier <= 1.000001)
        return min(slotBaseCost * count, 1e308);
    double result = slotBaseCost * (pow(slotMultiplier, count) - 1) / (slotMultiplier - 1);
    if (result > 1e308 || result != result) return 1e308;
    return result;
}
double calc_slot_cost(double count, double baseCost, double multiplier)
{
    if (multiplier <= 1.000001)
        return min(baseCost * count, 1e308);
    double result = baseCost * (pow(multiplier, count) - 1) / (multiplier - 1);
    if (result > 1e308 || result != result) return 1e308;
    return result;
}
