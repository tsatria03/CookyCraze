void apply_prestige_store_upgrade(string item_id)
{
    prestige_store_item[] items;
    prestige_menu_def[] menus;
    parse_prestige_store("data/config/stores/prestige.store", items, menus);
    for (uint i = 0; i < items.length(); i++)
    {
        if (items[i].item_id != item_id) continue;
        string id = items[i].item_id;
        double amt = items[i].amount;
        if (id.substr(0, 17) == "cookie_multiplier")
            prestige_cookie_multiplier += amt;
        else if (id.substr(0, 15) == "coin_multiplier")
            prestige_coin_multiplier += amt;
        else if (id.substr(0, 13) == "rank_discount")
            prestige_rank_discount += amt;
        else if (id.substr(0, 14) == "starting_coins")
            prestige_starting_coins += amt;
        else if (id.substr(0, 17) == "starting_autocookie")
            prestige_starting_autocookie += amt;
        else if (id.substr(0, 19) == "starting_manualcookie")
            prestige_starting_manualcookie += amt;
        break;
    }
}
void apply_all_prestige_store_upgrades()
{
    prestige_cookie_multiplier = 0;
    prestige_coin_multiplier = 0;
    prestige_rank_discount = 0;
    prestige_starting_coins = 0;
    prestige_starting_autocookie = 0;
    prestige_starting_manualcookie = 0;
    prestige_store_item[] items;
    prestige_menu_def[] menus;
    parse_prestige_store("data/config/stores/prestige.store", items, menus);
    for (uint i = 0; i < prestigePurchased.length(); i++)
    {
        for (uint j = 0; j < items.length(); j++)
        {
            if (items[j].item_id != prestigePurchased[i]) continue;
            string id = items[j].item_id;
            double amt = items[j].amount;
            if (id.substr(0, 17) == "cookie_multiplier")
                prestige_cookie_multiplier += amt;
            else if (id.substr(0, 15) == "coin_multiplier")
                prestige_coin_multiplier += amt;
            else if (id.substr(0, 13) == "rank_discount")
                prestige_rank_discount += amt;
            else if (id.substr(0, 14) == "starting_coins")
                prestige_starting_coins += amt;
            else if (id.substr(0, 17) == "starting_autocookie")
                prestige_starting_autocookie += amt;
            else if (id.substr(0, 19) == "starting_manualcookie")
                prestige_starting_manualcookie += amt;
            break;
        }
    }
}
void show_prestige_summary(int level, int rankReached, int questsDone, int questsTotal, string reward, int pointsEarned = 0)
{
    string txt = "Prestige level " + string(level) + " summary.\r\n";
    txt += "\r\n";
    txt += "Rank reached: " + string(rankReached) + "\r\n";
    txt += "Quests completed: " + string(questsDone) + " of " + string(questsTotal) + "\r\n";
    txt += "Reward: " + reward + "\r\n";
    if (pointsEarned > 0)
    {
        string pointWord = (pointsEarned == 1) ? "point" : "points";
        txt += "Your dedication paid off! You earned " + string(pointsEarned) + " prestige " + pointWord + " to spend in the prestige store.\r\n";
    }
    else
        txt += "No prestige points were earned this run. Complete quests before prestiging to earn points.\r\n";
    form.reset();
    form.create_window("Prestige summary", false);
    int summaryBox = form.create_input_box("Prestige summary", txt, read_only:true, multiline:true);
    int summaryClose = form.create_button("&Close", false, true);
    form.focus(summaryBox);
    while (true)
    {
        wait(5);
        form.monitor();
        if (form.is_pressed(summaryClose) || key_pressed(KEY_ESCAPE))
        {
            form.reset();
            return;
        }
    }
}

string get_stat_progress_label(string stat)
{
    if (stat == STAT_COOKIES_BAKED) return "cookies baked";
    if (stat == STAT_MANUAL_BAKES_PERFORMED) return "manual bakes performed";
    if (stat == STAT_AUTO_BAKES_PERFORMED) return "auto bakes performed";
    if (stat == STAT_COINS_EARNED) return "earned";
    if (stat == STAT_COINS_SPENT) return "spent";
    if (stat == STAT_SINGLES_PURCHASED) return "single upgrades purchased";
    if (stat == STAT_BUNDLES_PURCHASED) return "bundle upgrades purchased";
    if (stat == STAT_BAKER_EVENTS_FIRED) return "baker events fired";
    if (stat == STAT_FLIPPER_EVENTS_FIRED) return "flipper events fired";
    if (stat == STAT_FLIPPER_FLIPS) return "flips";
    if (stat == STAT_COOKY_FLIPS) return "cookie flips";
    if (stat == STAT_PENNY_FLIPS) return "penny flips";
    if (stat == STAT_DICE_ROLLS) return "dice rolls";
    if (stat == STAT_DICE_WINS) return "dice wins";
    if (stat == STAT_DICE_LOSSES) return "dice losses";
    if (stat == STAT_SLOT_SPINS) return "spins";
    if (stat == STAT_SLOT_WINS) return "wins";
    if (stat == STAT_SLOT_LOSSES) return "losses";
    if (stat == STAT_BLACKJACK_HANDS) return "hands played";
    if (stat == STAT_BLACKJACK_WINS) return "wins";
    if (stat == STAT_BLACKJACK_LOSSES) return "losses";
    if (stat == STAT_BLACKJACK_PUSHES) return "pushes";
    if (stat == STAT_AUTO_SLOTS_PURCHASED) return "auto slots purchased";
    if (stat == STAT_MANUAL_SLOTS_PURCHASED) return "manual slots purchased";
    if (stat == STAT_AUTO_SLOTS_ENABLED) return "auto slots enabled";
    if (stat == STAT_AUTO_SLOTS_IDLE) return "auto slots idle";
    if (stat == STAT_QUESTS_COMPLETED) return "quests completed";
    if (stat == STAT_REROLLS_PERFORMED) return "rerolls performed";
    return stat;
}

void show_achievement_statistics(achievement_item[]@ achievements, dictionary@ unlocked, achievement_category[]@ categories)
{
    int unlockedCount = unlocked.get_keys().length();
    double idleCount = double(baking_slots.length()) - double(autobakeSlots);
    string txt = "";
    int visibleTotal = 0;
    for (uint i = 0; i < achievements.length(); i++)
    {
        if (achievements[i].hidden && !unlocked.exists(achievements[i].id)) continue;
        visibleTotal++;
    }
    txt += "Achievement statistics. " + string(unlockedCount) + " of " + string(visibleTotal) + " complete.\r\n";
    for (uint c = 0; c < categories.length(); c++)
    {
        string catName = categories[c].name;
        bool hasAny = false;
        for (uint i = 0; i < achievements.length(); i++)
        {
            if (achievements[i].category != catName) continue;
            if (achievements[i].hidden && !unlocked.exists(achievements[i].id)) continue;
            hasAny = true;
            break;
        }
        if (!hasAny) continue;
        txt += "\r\n";
        txt += catName + "\r\n";
        for (uint i = 0; i < achievements.length(); i++)
        {
            if (achievements[i].category != catName) continue;
            if (achievements[i].hidden && !unlocked.exists(achievements[i].id)) continue;
            if (unlocked.exists(achievements[i].id))
            {
                double curVal = get_stat_value(achievements[i].stat);
                if (achievements[i].stat == STAT_AUTO_SLOTS_IDLE) curVal = idleCount;
                string label = get_stat_progress_label(achievements[i].stat);
                bool isCoinStat = (achievements[i].stat == STAT_COINS_EARNED || achievements[i].stat == STAT_COINS_SPENT);
                string curStr = isCoinStat ? convert_to_currency(curVal) : format_number(curVal);
                string threshStr = isCoinStat ? convert_to_currency(achievements[i].threshold) : format_number(achievements[i].threshold);
                txt += achievements[i].name + ", complete. " + curStr + " " + label + ".\r\n";
            }
        }
        for (uint i = 0; i < achievements.length(); i++)
        {
            if (achievements[i].category != catName) continue;
            if (achievements[i].hidden) continue;
            if (unlocked.exists(achievements[i].id)) continue;
            double curVal = get_stat_value(achievements[i].stat);
            if (achievements[i].stat == STAT_AUTO_SLOTS_IDLE) curVal = idleCount;
            string label = get_stat_progress_label(achievements[i].stat);
            bool isCoinStat = (achievements[i].stat == STAT_COINS_EARNED || achievements[i].stat == STAT_COINS_SPENT);
            string curStr = isCoinStat ? convert_to_currency(curVal) : format_number(curVal);
            string threshStr = isCoinStat ? convert_to_currency(achievements[i].threshold) : format_number(achievements[i].threshold);
            txt += achievements[i].name + ", incomplete. " + curStr + " of " + threshStr + " " + label + ".\r\n";
        }
    }
    form.reset();
    form.create_window("Achievement statistics", false);
    int statsbox = form.create_input_box("Achievement statistics", txt, read_only:true, multiline:true);
    int statsclose = form.create_button("&Close", false, true);
    form.focus(statsbox);
    while (true)
    {
        wait(5);
        form.monitor();
        if (form.is_pressed(statsclose) || key_pressed(KEY_ESCAPE))
        {
            form.reset();
            infomenu();
            return;
        }
    }
}

