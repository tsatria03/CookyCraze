[settings]

; Required header — removing or renaming this will break the file.

enabled=true:70

combo_window=2000,4000
start_count=25

start_sound=combos/start.ogg
stop_sound=combos/stop.ogg

start_message=Combo started! Keep pressing to build it up.
stop_message=Combo broke at %combo% %press%! Keep pressing to build it back up.

