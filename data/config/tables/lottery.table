[settings]

; Required header — removing or renaming this will break the file.

max_tickets=99

[prize:bronze]

; Required header — removing or renaming this will break the file.

bronze_loss:none:0:0:false:500:ticklose(1,3).ogg:No luck this time. Better scratch another one.
bronze_small_coins:coins:25:75:false:250:tickwin.ogg:Small win! You scratched up %amount%!
bronze_medium_coins:coins:100:200:false:100:tickwin.ogg:Not bad! You found %amount% under the coating!
bronze_cookies:cookies:5:20:false:120:tickwin.ogg:Lucky crumble! You uncovered %amount% cookies!
bronze_autocooky:autocooky:1:2:false:50:tickwin.ogg:Scratch surprise! You gained %amount% auto-cookies!
bronze_manulcooky:manulcooky:1:2:false:50:tickwin.ogg:Handy find! You gained %amount% manual cookies!

